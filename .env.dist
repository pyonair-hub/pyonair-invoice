SOLIDINVOICE_ENV=dev
SOLIDINVOICE_DEBUG=1

# MCP session store: file | memory | cache | framework
# - file: on-disk (default, single-node deployments)
# - memory: in-process (dev only; resets on restart)
# - cache: PSR-16 cache pool, configurable via SOLIDINVOICE_MCP_SESSION_CACHE_POOL
#   (point to a Redis-backed pool for multi-node)
# - framework: Symfony session.handler (shares the app's session storage)
SOLIDINVOICE_MCP_SESSION_STORE=file
SOLIDINVOICE_MCP_SESSION_CACHE_POOL=cache.mcp.sessions
SOLIDINVOICE_MCP_SESSION_PREFIX=mcp-
SOLIDINVOICE_MCP_SESSION_TTL=86400

# MCP OAuth2 token lifetimes (ISO 8601 durations). Longer access tokens mean
# fewer refresh-token round trips for connected AI agents.
SOLIDINVOICE_MCP_ACCESS_TOKEN_TTL=P1D
SOLIDINVOICE_MCP_REFRESH_TOKEN_TTL=P90D
SOLIDINVOICE_MCP_AUTH_CODE_TTL=PT10M
