<div {{ attributes }} class="mb-5">
    {# Section Header #}
    <div class="client-section-header">
        <h3 class="client-section-title">
            {{ ux_icon('tabler:users', {width: 20, height: 20, class: 'text-primary'}) }}
            {{ 'client.heading.contacts'|trans }}
            <span class="badge bg-secondary-lt">{{ client.contacts|length }}</span>
        </h3>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#add-contact">
            {{ ux_icon('tabler:plus', {width: 16, height: 16}) }}
            {{ 'client.view.actions.add_contact'|trans }}
        </button>
    </div>

    {# Contacts Grid #}
    <div class="row g-3">
        {% for contact in client.contacts %}
            <div class="col-md-6">
                <twig:ContactInfo :contact="contact" :key="contact.id" canDelete="{{ client.contacts|length > 1 }}" />
            </div>
        {% else %}
            <div class="col-12">
                <div class="empty">
                    <div class="empty-icon">
                        {{ ux_icon('tabler:user-off', {width: 48, height: 48}) }}
                    </div>
                    <p class="empty-title">{{ 'client.contacts.empty.title'|trans }}</p>
                    <p class="empty-subtitle text-secondary">{{ 'client.contacts.empty.description'|trans }}</p>
                    <div class="empty-action">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#add-contact">
                            {{ ux_icon('tabler:plus', {width: 16, height: 16}) }}
                            {{ 'client.view.actions.add_contact'|trans }}
                        </button>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Add Contact Modal #}
    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'save'
        }
    }) }}
    <twig:Ui:Modal id="add-contact" title="{{ 'Add Contact'|trans }}">
        {{ form_row(form) }}

        <twig:block name="footer">
            <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
            <button type="submit" class="btn btn-primary">
                {{ ux_icon('tabler:device-floppy', {width: 16, height: 16}) }}
                {{ 'Save'|trans }}
            </button>
        </twig:block>
    </twig:Ui:Modal>
    {{ form_end(form) }}
</div>
