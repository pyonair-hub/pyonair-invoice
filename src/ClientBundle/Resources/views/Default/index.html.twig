{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}
    {{ ux_icon('tabler:users-group', {width: 24, height: 24, class: 'me-2'}) }}{{ 'clients'|trans }}
{% endblock title %}

{% block heading %}
    <a class="btn btn-primary" href="{{ path("_clients_add") }}">
        {{ ux_icon('tabler:user-plus', {width: 18, height: 18}) }}
        {{ "client_create"|trans }}
    </a>
{% endblock %}

{% block content %}
    {# Stats Row #}
    <div class="row row-deck row-cards mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-primary text-white avatar">
                                {{ ux_icon('tabler:users', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ totalActiveClients }}
                            </div>
                            <div class="text-secondary">
                                {{ 'client.stats.active_clients'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-secondary text-white avatar">
                                {{ ux_icon('tabler:archive', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ totalArchivedClients }}
                            </div>
                            <div class="text-secondary">
                                {{ 'client.stats.archived_clients'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-info text-white avatar">
                                {{ ux_icon('tabler:address-book', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ totalContacts }}
                            </div>
                            <div class="text-secondary">
                                {{ 'client.stats.total_contacts'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-warning text-white avatar">
                                {{ ux_icon('tabler:currency-dollar', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {% for currency, amount in totalOutstanding %}
                                    {{ amount|formatCurrency(currency) }}{% if not loop.last %}<br>{% endif %}
                                {% else %}
                                    {{ 0|formatCurrency }}
                                {% endfor %}
                            </div>
                            <div class="text-secondary">
                                {{ 'client.stats.outstanding_balance'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Client List Card #}
    <twig:Ui:Card>
        <twig:block name="header">
            <div class="d-flex justify-content-between align-items-center w-100">
                <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs" role="tablist">
                    <li class="nav-item">
                        <a href="{{ path('_clients_index') }}" class="nav-link{{ not isArchived ? ' active' : '' }}">
                            {{ ux_icon('tabler:users', {width: 16, height: 16}) }}
                            {{ 'client.tabs.active'|trans }}
                            <span class="badge bg-primary-lt ms-2">{{ totalActiveClients }}</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('_clients_index', {archived: 1}) }}" class="nav-link{{ isArchived ? ' active' : '' }}">
                            {{ ux_icon('tabler:archive', {width: 16, height: 16}) }}
                            {{ 'client.tabs.archived'|trans }}
                            <span class="badge bg-secondary-lt ms-2">{{ totalArchivedClients }}</span>
                        </a>
                    </li>
                </ul>
            </div>
        </twig:block>

        {% if isArchived %}
            <twig:DataGrid name="archived_client_grid" />
        {% else %}
            <twig:DataGrid name="client_grid" />
        {% endif %}
    </twig:Ui:Card>
{% endblock %}
