{% extends "@SolidInvoiceCore/Layout/default_no_nav.html.twig" %}

{% block content %}
    <div class="company-create-page">
        {# Application Header #}
        <header class="company-page-header">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="company-page-logo">
                            {{ app_logo('48', showDefault: true, showOnlyAppIcon: true) }}
                        </div>
                        <div class="company-page-brand">
                            <h1 class="h3 mb-0">{{ app_name }}</h1>
                        </div>
                    </div>
                    {% if allowCancel %}
                        <div>
                            <a href="{{ path('_dashboard') }}" class="btn btn-ghost btn-sm">
                                {{ ux_icon('tabler:arrow-left', {width: 24, height: 24}) }} {{ 'Back'|trans }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </header>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8 col-xl-7">
                    {# Header Section #}
                    <div class="company-page-intro text-center mb-5">
                        <div class="d-flex align-items-center justify-content-center gap-3 mb-2">
                            <span class="avatar avatar-md rounded-circle bg-primary-lt">
                                {{ ux_icon('tabler:building', {width: 24, height: 24, class: 'text-primary'}) }}
                            </span>
                            <h2 class="h3 mb-0">{{ 'Create Your Company'|trans }}</h2>
                        </div>
                        <p class="text-secondary mb-0">{{ 'Set up your workspace and start managing your business in minutes'|trans }}</p>
                    </div>

                    {{ form_start(form, {'attr': {'class': 'form-smooth'}}) }}
                        <twig:Ui:Card>
                            <div class="card-body p-4 p-md-5">
                                {# Form Fields #}
                                <div class="mb-4">
                                    <div class="row g-4">
                                        <div class="col-12">
                                            {{ form_row(form.name, {
                                                'attr': {
                                                    'class': 'form-control-lg',
                                                    'placeholder': 'e.g., Acme Corporation'|trans,
                                                    'autofocus': 'autofocus'
                                                }
                                            }) }}
                                            <div class="form-hint mt-2">
                                                {{ ux_icon('tabler:info-circle', {width: 14, height: 14, class: 'me-1'}) }}
                                                {{ 'This will be displayed on your invoices and quotes'|trans }}
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            {{ form_row(form.currency, {
                                                'attr': {
                                                    'class': 'form-select-lg'
                                                }
                                            }) }}
                                            <div class="form-hint mt-2">
                                                {{ ux_icon('tabler:currency-dollar', {width: 14, height: 14, class: 'me-1'}) }}
                                                {{ 'All invoices and payments will use this currency'|trans }}
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                {# Divider #}
                                <hr class="my-4">

                                {# Pricing Information #}
                                {% toggle 'saas_enabled' %}
                                    {% if not userHasTrial and planHasTrial %}
                                        <div class="alert alert-info d-flex align-items-start" role="alert">
                                            <div class="me-3">
                                                {{ ux_icon('tabler:gift', {width: 24, height: 24}) }}
                                            </div>
                                            <div class="flex-fill">
                                                <div class="alert-title fw-semibold">{{ 'Start Your Free Trial'|trans }}</div>
                                                <div class="text-secondary mb-2">
                                                    {% apply spaceless %}
                                                        {% set trial_label %}
                                                            {% if trialDuration.y > 0 %}{{ '{1} %count% year|]1,Inf[ %count% years'|trans({'%count%': trialDuration.y}, count=trialDuration.y) }} {% endif %}
                                                            {% if trialDuration.m > 0 %}{{ '{1} %count% month|]1,Inf[ %count% months'|trans({'%count%': trialDuration.m}, count=trialDuration.m) }} {% endif %}
                                                            {% if trialDuration.d > 0 %}{{ '{1} %count% day|]1,Inf[ %count% days'|trans({'%count%': trialDuration.d}, count=trialDuration.d) }}{% endif %}
                                                        {% endset %}
                                                    {% endapply %}
                                                    {% trans with {'%duration%': trial_label|trim} %}Get full access for %duration%, completely free. No credit card required.{% endtrans %}
                                                </div>
                                                {% if planPrice %}
                                                    <div class="d-flex align-items-center gap-2 mt-2">
                                                        <span class="badge bg-info-lt">{{ 'Then'|trans }} {{ planPrice }}/{{ 'month'|trans }}</span>
                                                        <span class="text-muted small">{{ 'Cancel anytime'|trans }}</span>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="alert alert-warning d-flex align-items-start" role="alert">
                                            <div class="me-3">
                                                {{ ux_icon('tabler:credit-card', {width: 24, height: 24}) }}
                                            </div>
                                            <div class="flex-fill">
                                                <div class="alert-title fw-semibold">{{ 'Payment Required'|trans }}</div>
                                                <div class="text-secondary">
                                                    {% if userHasTrial %}
                                                        {{ 'You have already used your free trial.'|trans }}
                                                        {{ 'After creating this company, you\'ll choose a plan and proceed to checkout.'|trans }}
                                                    {% else %}
                                                        {{ 'Creating this company will require payment.'|trans }}
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <div class="alert alert-success d-flex align-items-start" role="alert">
                                        <div class="me-3">
                                            {{ ux_icon('tabler:infinity', {width: 24, height: 24}) }}
                                        </div>
                                        <div class="flex-fill">
                                            <div class="alert-title fw-semibold">{{ 'Self-Hosted Freedom'|trans }}</div>
                                            <div class="text-secondary">
                                                {{ 'Create unlimited companies at no additional cost. Your data, your control.'|trans }}
                                            </div>
                                        </div>
                                    </div>
                                {% endtoggle %}
                            </div>

                            <twig:block name="footer">
                                <div class="card-footer bg-transparent p-4">
                                    <div class="d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary btn-lg px-5">
                                            {{ ux_icon('tabler:rocket') }} {{ 'Create Company'|trans }}
                                        </button>
                                    </div>
                                </div>
                            </twig:block>
                        </twig:Ui:Card>
                    {{ form_end(form) }}

                    {# Help Section #}
                    <div class="text-center mt-4">
                        <div class="d-flex align-items-center justify-content-center gap-3 flex-wrap">
                            <span class="text-secondary">
                                {{ ux_icon('tabler:help-circle', {width: 16, height: 16}) }}
                                {{ 'Need assistance?'|trans }}
                            </span>
                            <a href="https://solidinvoice.co/docs" target="_blank" class="link-primary text-decoration-none">
                                {{ 'View Documentation'|trans }} {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
