{% extends "@SolidInvoiceCore/Layout/default_no_nav.html.twig" %}

{% block content %}
    <div class="company-select-page">
        {# Application Header #}
        <header class="company-page-header">
            <div class="container-xl">
                <div class="d-flex justify-content-between align-items-center py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="company-page-logo">
                            {{ app_logo('48', showDefault: true, showOnlyAppIcon: true) }}
                        </div>
                        <div class="company-page-brand">
                            <h1 class="h3 mb-0">{{ app_name }}</h1>
                        </div>
                    </div>
                    <div>
                        <twig:Ui:Security:LogoutLink size="sm" color="ghost" outline />
                    </div>
                </div>
            </div>
        </header>

        <div class="container-xl py-5">
            {# Welcome Section #}
            <div class="company-page-intro text-center mb-5">
                <div class="d-flex align-items-center justify-content-center gap-3 mb-2">
                    <span class="avatar avatar-md rounded-circle bg-primary-lt">
                        {{ ux_icon('tabler:users', {width: 24, height: 24, class: 'text-primary'}) }}
                    </span>
                    <h2 class="h3 mb-0">{{ 'Welcome Back %name%'|trans({'%name%': app.user.firstName}) }}</h2>
                </div>
                <p class="text-secondary mb-0">{{ 'Select a company to continue'|trans }}</p>
            </div>

            {# Main Company Selection Card #}
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    <div class="card shadow-sm">
                        <div class="card-body p-4 p-md-5">
                            {# Company Grid #}
                            <div class="row row-cols-1 row-cols-md-2 g-4">
                                {% for company in companies %}
                                    <div class="col">
                                        <a href="{{ path('_switch_company', {'id': company.id}) }}" class="card card-company h-100 text-decoration-none">
                                            <div class="card-body p-4">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="company-avatar">
                                                        {% set companyLogo = app_logo('64', company) %}
                                                        {% if companyLogo is not empty and companyLogo != '' %}
                                                            <div class="avatar avatar-2xl rounded-circle">
                                                                {{ app_logo('64', company) }}
                                                            </div>
                                                        {% else %}
                                                            {% set companyName = company.name %}
                                                            {% set initials = companyName|split(' ')|map(word => word|first)|join('')|upper|slice(0, 3) %}
                                                            <div class="avatar avatar-2xl rounded-circle bg-primary text-white" data-initials="{{ initials }}">
                                                                <span class="avatar-initials">{{ initials }}</span>
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                    <div class="flex-fill min-w-0">
                                                        <h3 class="h4 mb-1 text-truncate">{{ company }}</h3>
                                                        <p class="text-secondary mb-0 small">
                                                            {{ 'Click to access'|trans }}
                                                        </p>
                                                    </div>
                                                    <div class="company-arrow">
                                                        {{ ux_icon('tabler:chevron-right', {width: 20, height: 20, class: 'text-muted'}) }}
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Divider #}
                            <hr class="my-4">

                            {# Create New Company CTA #}
                            <div class="card card-create-company">
                                <div class="card-body p-4">
                                    <div class="row align-items-center g-3">
                                        <div class="col-auto">
                                            <div class="avatar avatar-lg rounded-circle bg-success-lt">
                                                {{ ux_icon('tabler:plus', {width: 32, height: 32, class: 'text-success'}) }}
                                            </div>
                                        </div>
                                        <div class="col">
                                            <h4 class="h5 mb-1">{{ 'Create New Company'|trans }}</h4>
                                            <p class="text-secondary mb-0 small">
                                                {{ 'Set up another workspace to manage a different business'|trans }}
                                            </p>
                                        </div>
                                        <div class="col-12 col-md-auto">
                                            <a href="{{ path('_create_company') }}" class="btn btn-primary w-100">
                                                {{ ux_icon('tabler:building-plus') }} {{ 'Create Company'|trans }}
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
