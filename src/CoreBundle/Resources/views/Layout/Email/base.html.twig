{% apply inline_css(source("@SolidInvoiceCore/Email/foundation.css.twig") ~ source("@SolidInvoiceCore/Email/modern.css.twig")) %}
    <!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
    <html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <meta charset="UTF-8"/>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <meta name="x-apple-disable-message-reformatting"/>
        <title>{{- block('title') is defined ? block('title') -}}</title>
        <style type="text/css">html{min-height: 100%;background: #f4f6fa;}</style>
        {{- block('head_extra') is defined ? block('head_extra') -}}
    </head>

    <body>
    <table class="body">
        <tr>
            <td class="float-center" align="center" valign="top">
                <center data-parsed="">
                    {# View online link (if provided in header block) #}
                    {% if block('header') is defined %}
                        <table align="center" class="container float-center" style="margin-top: 16px; Margin-top: 16px;">
                            <tbody>
                            <tr>
                                <td align="center">
                                    {{- block('header') -}}
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    {% endif %}

                    <table class="spacer float-center">
                        <tbody>
                        <tr>
                            <td height="16px" style="font-size:16px;line-height:16px;">&#xA0;</td>
                        </tr>
                        </tbody>
                    </table>

                    {# Company header with logo #}
                    <table align="center" class="container header float-center modern">
                        <tbody>
                        <tr>
                            <td class="pad" style="background: #f4f6fa; border-radius: 8px 8px 0 0; padding: 24px 16px;">
                                {% apply inky_to_html %}
                                    <row>
                                        <columns large="12" small="12">
                                            <center>
                                                {{- app_logo(100, null, true) -}}
                                                <p style="font-size: 20px; font-weight: 700; color: #1e293b; margin: 12px 0 0 0; Margin: 12px 0 0 0; line-height: 1.3;">
                                                    {{- setting('system/company/company_name') -}}
                                                </p>
                                            </center>
                                        </columns>
                                    </row>
                                {% endapply %}
                            </td>
                        </tr>
                        </tbody>
                    </table>
                    <table align="center" class="container body-drip float-center modern">
                        <tbody>
                        <tr>
                            <td style="background: #ffffff; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);">
                                <table class="spacer">
                                    <tbody>
                                    <tr>
                                        <td height="24px" style="font-size:24px;line-height:24px;">&#xA0;</td>
                                    </tr>
                                    </tbody>
                                </table>
                                <table class="row">
                                    <tbody>
                                    <tr>
                                        <th class="small-12 large-12 columns first last">
                                            <table>
                                                <tr>
                                                    <th style="padding: 0 24px;">
                                                        <h2 class="text-center" style="color: #1e293b; font-size: 22px; font-weight: 700; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                                                            {{- block('title') is defined ? block('title') -}}
                                                        </h2>
                                                    </th>
                                                    <th class="expander"></th>
                                                </tr>
                                            </table>
                                        </th>
                                    </tr>
                                    </tbody>
                                </table>
                                <hr style="border: none; border-top: 1px solid #e6e7e9; margin: 0; Margin: 0;">
                                <table class="row">
                                    <tbody>
                                    <tr>
                                        <th class="small-12 large-12 columns first last">
                                            <table>
                                                <tr>
                                                    <th style="padding: 24px;">
                                                        {{- block('content') is defined ? block('content') -}}
                                                    </th>
                                                    <th class="expander"></th>
                                                </tr>
                                            </table>
                                        </th>
                                    </tr>
                                    </tbody>
                                </table>
                                <table class="row collapsed footer modern">
                                    <tbody>
                                    <tr>
                                        <th class="small-12 large-12 columns first last">
                                            <table>
                                                <tr>
                                                    <th style="padding: 24px; background: #f4f6fa; border-top: 1px solid #e6e7e9; border-radius: 0 0 8px 8px;">
                                                        {% set footer = block('footer') is defined ? block('footer') %}
                                                        {% if footer %}
                                                            <center data-parsed="">
                                                                {{- footer|raw -}}
                                                            </center>
                                                        {% endif %}
                                                    </th>
                                                    <th class="expander"></th>
                                                </tr>
                                            </table>
                                        </th>
                                    </tr>
                                    </tbody>
                                </table>
                                <table class="spacer">
                                    <tbody>
                                    <tr>
                                        <td height="24px" style="font-size:24px;line-height:24px;">&#xA0;</td>
                                    </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </center>
            </td>
        </tr>
    </table>
    </body>
    </html>
{% endapply %}
