{% extends '@SolidInvoiceCore/Layout/base.html.twig' %}

{% block body %}
    <div class="page page-center">
        <div class="container py-4">
            {# App Branding #}
            <div class="text-center mb-4">
                <a href="{{ url('_dashboard') }}" class="navbar-brand navbar-brand-autodark">
                    <span class="d-flex align-items-center justify-content-center gap-2">
                        {{ app_logo(showDefault: true, showOnlyAppIcon: true) }}
                        <span class="h2 mb-0 fw-bold">{{ app_name }}</span>
                    </span>
                </a>
            </div>

            {# Flash Messages #}
            {% for type, flashMessage in app.session.flashbag.all() %}
                {% if type == 'error' %}
                    {% set type = 'danger' %}
                {% endif %}

                {% for message in flashMessage %}
                    <div class="alert alert-{{ type }} alert-dismissible no-print" role="alert">
                        <div class="d-flex align-items-start gap-2">
                            {% if type == 'danger' %}
                                {{ ux_icon('tabler:alert-circle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1'}) }}
                            {% elseif type == 'success' %}
                                {{ ux_icon('tabler:check', {width: 20, height: 20, class: 'flex-shrink-0 mt-1'}) }}
                            {% elseif type == 'warning' %}
                                {{ ux_icon('tabler:alert-triangle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1'}) }}
                            {% else %}
                                {{ ux_icon('tabler:info-circle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1'}) }}
                            {% endif %}
                            <div class="flex-grow-1">
                                {{ message|trans }}
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# Main Content #}
            {{ block('content') is defined ? block('content') }}
        </div>
    </div>
{% endblock body %}
