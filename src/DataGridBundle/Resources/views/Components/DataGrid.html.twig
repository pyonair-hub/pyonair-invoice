{# @var paginator \Pagerfanta\Pagerfanta #}
{# @var grid \SolidInvoice\DataGridBundle\GridInterface #}

<div {{ attributes.defaults({class: 'datagrid'}) }}>
    {% include "@SolidInvoiceCore/flash.html.twig" %}

    {# Main Card Container #}
    <div class="card">
        {# Toolbar: Search, Filters, Column Picker #}
        <div class="datagrid-toolbar">
            <div class="datagrid-toolbar-start">
                {# Search Input #}
                <div class="datagrid-search">
                    <span class="datagrid-search-icon">
                        {{ ux_icon('tabler:search', {width: 18, height: 18}) }}
                    </span>
                    <input
                        type="search"
                        class="datagrid-search-input"
                        placeholder="{{ 'Search...'|trans }}"
                        aria-label="{{ 'Search'|trans }}"
                        value="{{ search }}"
                        data-model="debounce(300)|search"
                    >
                </div>

                {# Active Filter Chips #}
                {% if gridFilters is not empty %}
                    <div class="datagrid-active-filters">
                        {% for key, value in gridFilters %}
                            {% set displayValue = value %}
                            {% if value is iterable %}
                                {# Handle date range filters #}
                                {% if value.start is defined or value.end is defined %}
                                    {% set parts = [] %}
                                    {% if value.start is defined and value.start %}
                                        {% set parts = parts|merge(['From: ' ~ value.start]) %}
                                    {% endif %}
                                    {% if value.end is defined and value.end %}
                                        {% set parts = parts|merge(['To: ' ~ value.end]) %}
                                    {% endif %}
                                    {% set displayValue = parts|join(' ') %}
                                {% else %}
                                    {% set displayValue = value|join(', ') %}
                                {% endif %}
                            {% endif %}

                            <button
                                type="button"
                                class="datagrid-active-filter"
                                data-action="live#action:prevent"
                                data-live-action-param="removeFilter"
                                data-live-filter-key-param="{{ key }}"
                                title="{{ 'Click to remove'|trans }}"
                            >
                                <span class="datagrid-active-filter-key">{{ key|replace({'_': ' '})|title }}</span>
                                <span class="datagrid-active-filter-value">{{ displayValue }}</span>
                                {{ ux_icon('tabler:x', {width: 14, height: 14, class: 'datagrid-active-filter-remove'}) }}
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="datagrid-toolbar-end">
                {# Advanced Filters Panel #}
                {% if grid.filters|length > 0 %}
                    <div class="dropdown datagrid-filter-dropdown">
                        <button
                            type="button"
                            class="btn btn-sm {{ gridFilters is not empty ? 'btn-primary' : 'btn-ghost' }}"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false"
                            aria-label="{{ 'Filters'|trans }}"
                        >
                            {{ ux_icon('tabler:filter', {width: 18, height: 18}) }}
                            <span class="d-none d-sm-inline ms-1">{{ 'Filters'|trans }}</span>
                            {% if gridFilters is not empty %}
                                <span class="badge bg-white text-primary rounded-pill ms-1">{{ gridFilters|length }}</span>
                            {% endif %}
                        </button>
                        <div class="dropdown-menu dropdown-menu-end datagrid-filter-panel">
                            <div class="datagrid-filter-panel-header">
                                <h6 class="datagrid-filter-panel-title">
                                    {{ ux_icon('tabler:filter', {width: 16, height: 16}) }}
                                    {{ 'Filters'|trans }}
                                </h6>
                            </div>

                            <div class="datagrid-filter-panel-body">
                                {{ form_start(form, {attr: {class: 'datagrid-filter-form', 'data-model': 'norender'}}) }}

                                {% for child in form.children|filter(c => c.vars.name != '_token') %}
                                    <div class="datagrid-filter-field">
                                        <label class="datagrid-filter-label">
                                            {{ child.vars.name|replace({'_': ' '})|title }}
                                        </label>
                                        <div class="datagrid-filter-widget">
                                            {# Check if this is an expanded choice (checkboxes/radios) #}
                                            {% if child.vars.expanded is defined and child.vars.expanded %}
                                                {# Render each choice as a properly labeled checkbox #}
                                                {% for choice in child.children %}
                                                    <div class="form-check">
                                                        {{ form_widget(choice, {attr: {class: 'form-check-input'}}) }}
                                                        <label class="form-check-label" for="{{ choice.vars.id }}">
                                                            {{ choice.vars.label }}
                                                        </label>
                                                    </div>
                                                {% endfor %}
                                            {% else %}
                                                {{ form_widget(child) }}
                                            {% endif %}
                                        </div>
                                        {{ form_errors(child) }}
                                    </div>
                                {% endfor %}

                                {{ form_rest(form) }}

                                <div class="datagrid-filter-panel-footer">
                                    <div class="d-flex gap-2">
                                        <button
                                            type="button"
                                            class="btn btn-ghost flex-fill"
                                            data-action="live#action:prevent"
                                            data-live-action-param="clearFilters"
                                        >
                                            {{ 'Clear'|trans }}
                                        </button>
                                        <button
                                            type="submit"
                                            class="btn btn-primary flex-fill"
                                            data-action="live#action:prevent"
                                            data-live-action-param="applyFilters"
                                        >
                                            {{ ux_icon('tabler:check', {width: 16, height: 16}) }}
                                            {{ 'Apply'|trans }}
                                        </button>
                                    </div>
                                </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Column Visibility Picker #}
                {% block column_picker %}
                    {% if grid.columns|length > 3 %}
                        <div class="dropdown datagrid-column-picker">
                            <button
                                type="button"
                                class="dropdown-toggle"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                aria-label="{{ 'Columns'|trans }}"
                                title="{{ 'Show/Hide Columns'|trans }}"
                            >
                                {{ ux_icon('tabler:columns-3', {width: 18, height: 18}) }}
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                {% for column in grid.columns %}
                                    <label class="dropdown-item">
                                        <input
                                            type="checkbox"
                                            {{ this.isColumnVisible(column.getField()) ? 'checked' : '' }}
                                            data-action="live#action:prevent"
                                            data-live-action-param="toggleColumn"
                                            data-live-field-param="{{ column.getField() }}"
                                        >
                                        {{ column.getLabel|trans }}
                                    </label>
                                {% endfor %}
                                {% if hiddenColumns|length > 0 %}
                                    <div class="dropdown-divider"></div>
                                    <a
                                        href="#"
                                        class="dropdown-item text-primary"
                                        data-action="live#action:prevent"
                                        data-live-action-param="resetColumns"
                                    >
                                        {{ ux_icon('tabler:refresh', {width: 16, height: 16}) }}
                                        {{ 'Reset to default'|trans }}
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                {% endblock %}
            </div>
        </div>

        {# Data Table #}
        <div class="datagrid-table-wrapper">
            <table class="datagrid-table" {{ stimulus_controller('checkbox-select-all') }}>
                <thead>
                    <tr>
                        {# Checkbox Column #}
                        {% if grid.batchActions|length > 0 %}
                            <th class="col-checkbox">
                                <div class="datagrid-checkbox">
                                    <input
                                        type="checkbox"
                                        {{ stimulus_target('checkbox-select-all', 'checkboxAll') }}
                                        data-model="selectedAll"
                                        aria-label="{{ 'Select all'|trans }}"
                                    />
                                </div>
                            </th>
                        {% endif %}

                        {# Expand Column for Row Details #}
                        {% if grid.hasRowDetails() %}
                            <th class="col-expand">
                                <span class="visually-hidden">{{ 'Expand'|trans }}</span>
                            </th>
                        {% endif %}

                        {# Data Columns #}
                        {% for column in this.getVisibleColumns() %}
                            <th>
                                {% if column.isSortable %}
                                    <a
                                        href="#"
                                        class="datagrid-sort-link {{ sortField is same as column.getSortableField ? 'sorted' : '' }}"
                                        data-model="sort"
                                        data-value="{{ column.getSortableField }},{{ sortDir is same as('asc') ? 'desc' : 'asc'}}"
                                        data-action="live#update:prevent"
                                    >
                                        {{ column.getLabel|trans }}
                                        {% if sortField is same as column.getSortableField %}
                                            <span class="datagrid-sort-icon">
                                                {{ ux_icon(sortDir is same as('asc') ? 'tabler:chevron-up' : 'tabler:chevron-down', {width: 14, height: 14}) }}
                                            </span>
                                        {% endif %}
                                    </a>
                                {% else %}
                                    {{ column.getLabel|trans }}
                                {% endif %}
                            </th>
                        {% endfor %}

                        {# Actions Column #}
                        {% if grid.actions|length > 0 or grid.batchActions|length > 0 %}
                            <th class="col-actions">
                                <span class="visually-hidden">{{ 'Actions'|trans }}</span>
                            </th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% if paginator.nbResults is same as(0) %}
                        {# Empty State #}
                        <tr>
                            <td colspan="{{ this.getVisibleColumns()|length + (grid.batchActions|length > 0 ? 1 : 0) + (grid.hasRowDetails() ? 1 : 0) + (grid.actions|length > 0 ? 1 : 0) }}">
                                <div class="datagrid-empty">
                                    <div class="datagrid-empty-icon">
                                        {{ ux_icon('tabler:database-off', {width: 40, height: 40}) }}
                                    </div>
                                    <h3 class="datagrid-empty-title">{{ 'No results found'|trans }}</h3>
                                    <p class="datagrid-empty-message">
                                        {% if search is not empty or gridFilters is not empty %}
                                            {{ 'Try adjusting your search or filters to find what you\'re looking for.'|trans }}
                                        {% else %}
                                            {{ 'Get started by creating your first item.'|trans }}
                                        {% endif %}
                                    </p>
                                    {% block empty_state_action %}
                                        {% if grid.getCreateRoute() %}
                                            <div class="datagrid-empty-action">
                                                <a href="{{ path(grid.getCreateRoute()) }}" class="btn btn-primary">
                                                    {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
                                                    {{ grid.getCreateLabel()|default('Create')|trans }}
                                                </a>
                                            </div>
                                        {% endif %}
                                    {% endblock %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        {# Data Rows #}
                        {% for row in paginator %}
                            <tr class="{{ this.entityId(row) in selectedItems ? 'selected' : '' }}" {% if grid.hasRowDetails() %}{{ stimulus_controller('datagrid-row-expand') }}{% endif %}>
                                {# Selection Checkbox #}
                                {% if grid.batchActions|length > 0 %}
                                    <td class="col-checkbox">
                                        <div class="datagrid-checkbox">
                                            <input
                                                type="checkbox"
                                                {{ stimulus_target('checkbox-select-all', 'checkbox') }}
                                                value="{{ this.entityId(row) }}"
                                                data-model="selectedItems"
                                                {{ this.entityId(row) in selectedItems ? 'checked' : '' }}
                                                aria-label="{{ 'Select row'|trans }}"
                                            />
                                        </div>
                                    </td>
                                {% endif %}

                                {# Expand Button #}
                                {% if grid.hasRowDetails() %}
                                    <td class="col-expand">
                                        <button
                                            type="button"
                                            class="datagrid-expand-btn"
                                            {{ stimulus_action('datagrid-row-expand', 'toggle') }}
                                            aria-label="{{ 'Expand row'|trans }}"
                                        >
                                            <span {{ stimulus_target('datagrid-row-expand', 'expandIcon') }}>
                                                {{ ux_icon('tabler:chevron-right', {width: 16, height: 16}) }}
                                            </span>
                                        </button>
                                    </td>
                                {% endif %}

                                {# Data Cells #}
                                {% for column in this.getVisibleColumns() %}
                                    <td{% if column.getCellClass() %} class="{{ column.getCellClass() }}"{% endif %}>{{ this.renderfield(column, row)|raw }}</td>
                                {% endfor %}

                                {# Row Actions #}
                                {% if grid.actions|length > 0 or grid.batchActions|length > 0 %}
                                    <td class="col-actions">
                                        <div class="datagrid-row-actions">
                                            {# Primary actions as icon buttons #}
                                            {% for action in grid.actions %}
                                                {% if action.isPrimary() %}
                                                    {% set params = {} %}
                                                    {% for p, v in action.parameters %}
                                                        {% set params = params|merge({(p): attribute(row, v)}) %}
                                                    {% endfor %}

                                                    <a
                                                        href="{{ path(action.getRoute, params) }}"
                                                        class="datagrid-action-btn action-{{ action.getLabel|lower|replace({' ': '-'}) }}"
                                                        title="{{ action.getLabel|trans }}"
                                                        aria-label="{{ action.getLabel|trans }}"
                                                    >
                                                        {{ ux_icon('tabler:' ~ action.getIcon, {width: 18, height: 18}) }}
                                                    </a>
                                                {% endif %}
                                            {% endfor %}

                                            {# Three-dot menu for secondary actions and batch actions #}
                                            {% set menuActions = grid.actions|filter(a => not a.isPrimary()) %}
                                            {% if menuActions|length > 0 or grid.batchActions|length > 0 %}
                                                <div class="dropdown datagrid-more-menu">
                                                    <button
                                                        type="button"
                                                        class="datagrid-action-btn datagrid-more-btn"
                                                        data-bs-toggle="dropdown"
                                                        aria-expanded="false"
                                                        aria-label="{{ 'More actions'|trans }}"
                                                    >
                                                        {{ ux_icon('tabler:dots-vertical', {width: 18, height: 18}) }}
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        {# Menu actions (non-primary route-based actions) #}
                                                        {% for action in menuActions %}
                                                            {% set params = {} %}
                                                            {% for p, v in action.parameters %}
                                                                {% set params = params|merge({(p): attribute(row, v)}) %}
                                                            {% endfor %}
                                                            <li>
                                                                <a
                                                                    href="{{ path(action.getRoute, params) }}"
                                                                    class="dropdown-item {{ action.getColor == 'danger' ? 'text-danger' : '' }}"
                                                                >
                                                                    {% if action.getIcon %}
                                                                        {{ ux_icon('tabler:' ~ action.getIcon, {width: 16, height: 16}) }}
                                                                    {% endif %}
                                                                    {{ action.getLabel|trans }}
                                                                </a>
                                                            </li>
                                                        {% endfor %}

                                                        {# Divider if both menu actions and batch actions exist #}
                                                        {% if menuActions|length > 0 and grid.batchActions|length > 0 %}
                                                            <li><hr class="dropdown-divider"></li>
                                                        {% endif %}

                                                        {# Batch actions available for single item #}
                                                        {% for action in grid.batchActions %}
                                                            <li>
                                                                {% if action.shouldConfirm %}
                                                                    {% set modalId = 'row_modal_' ~ action.getLabel|u.snake ~ '_' ~ loop.index ~ '_' ~ this.entityId(row) %}
                                                                    <button
                                                                        type="button"
                                                                        class="dropdown-item {{ action.getColor == 'danger' ? 'text-danger' : '' }}"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#{{ modalId }}"
                                                                    >
                                                                        {% if action.getIcon %}
                                                                            {{ ux_icon('tabler:' ~ action.getIcon, {width: 16, height: 16}) }}
                                                                        {% endif %}
                                                                        {{ action.getLabel|trans }}
                                                                    </button>
                                                                {% else %}
                                                                    <button
                                                                        type="button"
                                                                        class="dropdown-item {{ action.getColor == 'danger' ? 'text-danger' : '' }}"
                                                                        data-action="live#action"
                                                                        data-live-action-param="executeSingleAction"
                                                                        data-live-action-name-param="{{ action.getLabel }}"
                                                                        data-live-entity-id-param="{{ this.entityId(row) }}"
                                                                    >
                                                                        {% if action.getIcon %}
                                                                            {{ ux_icon('tabler:' ~ action.getIcon, {width: 16, height: 16}) }}
                                                                        {% endif %}
                                                                        {{ action.getLabel|trans }}
                                                                    </button>
                                                                {% endif %}
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </td>
                                {% endif %}
                            </tr>

                            {# Expandable Row Detail #}
                            {% if grid.hasRowDetails() %}
                                <tr class="datagrid-detail-row">
                                    <td colspan="{{ this.getVisibleColumns()|length + (grid.batchActions|length > 0 ? 1 : 0) + (grid.hasRowDetails() ? 1 : 0) + (grid.actions|length > 0 ? 1 : 0) }}">
                                        <div class="datagrid-detail-content">
                                            {# Render as Twig component for ApiTokenHistory #}
                                            {% if grid.getRowDetailTemplate() == '@SolidInvoiceUser/Components/ApiTokenHistory.html.twig' %}
                                                <twig:ApiTokenHistory :token="this.entityId(row)" />
                                            {% else %}
                                                {% include grid.getRowDetailTemplate() with {token: this.entityId(row)} %}
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>

        {# Footer: Pagination & Per-page #}
        {% if paginator.nbResults > 0 %}
            <div class="datagrid-footer">
                <div class="datagrid-footer-info">
                    {{ 'Showing %start% - %end% of %total% results'|trans({
                        '%start%': paginator.currentPageOffsetStart,
                        '%end%': paginator.currentPageOffsetEnd,
                        '%total%': paginator.nbResults
                    }) }}
                </div>

                <div class="datagrid-per-page">
                    <span>{{ 'Show'|trans }}</span>
                    <select data-model="perPage" aria-label="{{ 'Items per page'|trans }}">
                        <option value="10" {{ perPage == 10 ? 'selected' : '' }}>10</option>
                        <option value="25" {{ perPage == 25 ? 'selected' : '' }}>25</option>
                        <option value="50" {{ perPage == 50 ? 'selected' : '' }}>50</option>
                        <option value="{{ paginator.nbResults }}" {{ perPage == paginator.nbResults ? 'selected' : '' }}>{{ 'All'|trans }}</option>
                    </select>
                </div>

                <div class="datagrid-pagination">
                    {{ pagerfanta(paginator, 'twitter_bootstrap5', {
                        'prev_message': ux_icon('tabler:chevron-left', {width: 16, height: 16}),
                        'next_message': ux_icon('tabler:chevron-right', {width: 16, height: 16})
                    }) }}
                </div>
            </div>
        {% endif %}
    </div>

    {# Floating Bulk Action Bar #}
    {% if grid.batchActions|length > 0 %}
        <div class="datagrid-bulk-bar {{ selectedItems|length > 0 ? 'visible' : '' }}" role="toolbar" aria-label="{{ 'Bulk actions'|trans }}">
            <div class="datagrid-bulk-bar-inner">
                <div class="datagrid-bulk-count">
                    <span class="count">{{ selectedItems|length }}</span>
                    {{ 'selected'|trans }}
                </div>

                <div class="datagrid-bulk-divider"></div>

                <div class="datagrid-bulk-actions">
                    {% for action in grid.batchActions %}
                        {% set modalId = 'modal_' ~ action.getLabel|u.snake %}

                        {% if action.shouldConfirm %}
                            <button
                                type="button"
                                class="datagrid-bulk-btn {{ action.getColor == 'danger' ? 'btn-danger' : '' }}"
                                data-bs-toggle="modal"
                                data-bs-target="#{{ modalId }}"
                            >
                                {% if action.getIcon is not empty %}
                                    {{ ux_icon('tabler:' ~ action.getIcon, {width: 16, height: 16}) }}
                                {% endif %}
                                {{ action.getLabel|trans }}
                            </button>
                        {% else %}
                            <button
                                type="button"
                                class="datagrid-bulk-btn {{ action.getColor == 'danger' ? 'btn-danger' : '' }}"
                                data-action="live#action"
                                data-live-action-name-param="{{ action.getLabel }}"
                                data-live-action-param="debounce(300)|executeBatchAction"
                            >
                                {% if action.getIcon is not empty %}
                                    {{ ux_icon('tabler:' ~ action.getIcon, {width: 16, height: 16}) }}
                                {% endif %}
                                {{ action.getLabel|trans }}
                            </button>
                        {% endif %}
                    {% endfor %}
                </div>

                <div class="datagrid-bulk-divider"></div>

                <button
                    type="button"
                    class="datagrid-bulk-close"
                    data-action="live#action:prevent"
                    data-live-action-param="clearSelection"
                    aria-label="{{ 'Clear selection'|trans }}"
                >
                    {{ ux_icon('tabler:x', {width: 18, height: 18}) }}
                </button>
            </div>
        </div>
        
        {% set gridComponent = this %}

        {# Confirmation Modals for Batch Actions #}
        {% for action in grid.batchActions %}
            {% if action.shouldConfirm %}
                {% set modalId = 'modal_' ~ action.getLabel|u.snake %}
                <twig:Ui:Modal id="{{ modalId }}" title="{{ 'Confirm'|trans }}" status="{{ action.getColor|default('primary') }}">
                    <p>{{ action.getConfirmMessage|default('Are you sure you want to perform this action on the selected items?')|trans|nl2br }}</p>

                    <twig:block name="footer">
                        <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">
                            {{ 'Cancel'|trans }}
                        </button>
                        <button
                            type="button"
                            class="btn btn-{{ action.getColor|default('primary') }}"
                            data-bs-dismiss="modal"
                            data-action="live#action"
                            data-live-action-name-param="{{ action.getLabel }}"
                            data-live-action-param="debounce(300)|executeBatchAction"
                        >
                            {{ 'Confirm'|trans }}
                        </button>
                    </twig:block>
                </twig:Ui:Modal>
            {% endif %}
        {% endfor %}

        {# Confirmation Modals for Single Row Actions #}
        {% for row in paginator %}
            {% for action in grid.batchActions %}
                {% if action.shouldConfirm %}
                    {% set modalId = 'row_modal_' ~ action.getLabel|u.snake ~ '_' ~ loop.index ~ '_' ~ this.entityId(row) %}
                    <twig:Ui:Modal id="{{ modalId }}" title="{{ 'Confirm'|trans }}" status="{{ action.getColor|default('primary') }}">
                        <p>{{ action.getConfirmMessage|default('Are you sure you want to perform this action?')|trans|nl2br }}</p>

                        <twig:block name="footer">
                            <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">
                                {{ 'Cancel'|trans }}
                            </button>
                            <button
                                type="button"
                                class="btn btn-{{ action.getColor|default('primary') }}"
                                data-bs-dismiss="modal"
                                data-action="live#action"
                                data-live-action-param="executeSingleAction"
                                data-live-action-name-param="{{ action.getLabel }}"
                                data-live-entity-id-param="{{ gridComponent.entityId(row) }}"
                            >
                                {{ 'Confirm'|trans }}
                            </button>
                        </twig:block>
                    </twig:Ui:Modal>
                {% endif %}
            {% endfor %}
        {% endfor %}
    {% endif %}
</div>
