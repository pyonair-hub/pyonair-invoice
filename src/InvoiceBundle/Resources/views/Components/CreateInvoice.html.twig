<div {{ attributes.defaults({class: 'billing-form-page'}) }}>
    {% set currency = dto.client ? dto.client.currency : null %}

    {{ form_start(form) }}

    <div class="billing-form-container">
        {# Page Header #}
        <div class="billing-form-header">
            <div class="billing-form-header-content">
                <div class="billing-form-icon">
                    {{ ux_icon('tabler:file-invoice', {width: 28, height: 28}) }}
                </div>
                <div>
                    {% if isEdit %}
                        <h1 class="billing-form-title">{{ 'invoice.edit.title'|trans }}</h1>
                    {% else %}
                        <h1 class="billing-form-title">{{ 'invoice.create.title'|trans }}</h1>
                        <p class="billing-form-subtitle">{{ 'invoice.create.subtitle'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Invoice Details Section (Client, Invoice ID, Dates) #}
        <div class="billing-details-section">
            <div class="billing-details-grid">
                {# Left Column: Client Selection + Invoice ID #}
                <div class="billing-details-left">
                    {# Client Selection #}
                    <div class="client-selection">
                        {# Mode Toggle #}
                        <div class="client-mode-toggle mb-3{{ not this.hasClients() ? ' d-none' }}">
                            {{ form_row(form.clientMode, {'attr': {'class': 'd-flex gap-2'}}) }}
                        </div>

                        {% set mode = form.clientMode.vars.data %}

                        {% if mode.value == 'existing' %}
                            {# Existing client selection (autocomplete or info card) #}
                            <div{{ form.client is defined and form.client.vars.data is not empty ? ' class="d-none"' }}>
                                {% if form.client is defined %}
                                    {{ form_row(form.client, {attr: {'data-action': 'live#$render'}}) }}
                                {% endif %}
                            </div>
                            {% if form.client is defined and form.client.vars.data %}
                                {% include "@SolidInvoiceClient/Ajax/info.html.twig" with {'client': form.client.vars.data, 'form': form} %}
                            {% endif %}
                        {% else %}
                            {# New client inline form #}
                            <div class="inline-client-form card">
                                <div class="card-body">
                                    <div class="inline-client-header mb-3">
                                        <h3 class="h5 mb-0">
                                            {{ ux_icon('tabler:user-plus', {width: 20, height: 20}) }}
                                            {{ 'invoice.client.create_new'|trans }}
                                        </h3>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-12">
                                            {{ form_row(form.newClientName) }}
                                        </div>
                                        <div class="col-md-6">
                                            {{ form_row(form.newContactFirstName) }}
                                        </div>
                                        <div class="col-md-6">
                                            {{ form_row(form.newContactLastName) }}
                                        </div>
                                        <div class="col-12">
                                            {{ form_row(form.newContactEmail) }}
                                        </div>
                                    </div>

                                    <div class="alert alert-info mt-3 mb-0">
                                        {{ ux_icon('tabler:info-circle', {width: 16, height: 16}) }}
                                        <small>{{ 'invoice.client.inline.currency_note'|trans }}</small>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    {# Invoice ID #}
                    <div {{ stimulus_controller('billing-id') }}>
                        <span {{ stimulus_target('billing-id', 'info') }}>
                            <div class="billing-id-display">
                                <span class="billing-id-label">{{ 'invoice.label'|trans }}</span>
                                <span class="billing-id-value" {{ stimulus_target('billing-id', 'value') }}>{{ form.invoiceId.vars.data }}</span>
                                {% if editInvoiceId is not defined or editInvoiceId is not same as(false) %}
                                    <button type="button" class="billing-id-edit" {{ stimulus_action('billing-id', 'edit') }} aria-label="{{ 'invoice.id.edit'|trans }}" title="{{ 'Edit'|trans }}">
                                        {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                                    </button>
                                {% endif %}
                            </div>
                        </span>

                        <div class="d-none billing-id-form" {{ stimulus_target('billing-id', 'form') }}>
                            {{ form_label(form.invoiceId) }}
                            <div class="input-group">
                                {{ form_widget(form.invoiceId, {attr: {class: 'form-control'}}) }}
                                <button class="btn btn-outline-primary" type="button" {{ stimulus_action('billing-id', 'save') }} aria-label="{{ 'invoice.id.save'|trans }}" title="{{ 'Save'|trans }}">
                                    {{ ux_icon('tabler:check', {width: 18, height: 18}) }}
                                </button>
                                <button class="btn btn-outline-secondary" type="button" {{ stimulus_action('billing-id', 'cancel') }} aria-label="{{ 'invoice.id.cancel'|trans }}" title="{{ 'Cancel'|trans }}">
                                    {{ ux_icon('tabler:x', {width: 18, height: 18}) }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                {# Right Column: Dates + Discount #}
                <div class="billing-details-right">
                    <div class="invoice-dates-row">
                        {{ form_row(form.invoiceDate) }}
                        {{ form_row(form.due) }}
                    </div>
                    {{ form_row(form.discount) }}
                </div>
            </div>
        </div>

        {# Main Content: 2-Column Layout #}
        <div class="billing-form-main">
            {# Line Items Section #}
            <div class="billing-items-section">
                <div class="billing-items-header">
                    <div class="billing-items-icon">
                        {{ ux_icon('tabler:list-details', {width: 20, height: 20}) }}
                    </div>
                    <h2 class="billing-items-title">{{ 'invoice.items.title'|trans }}</h2>
                </div>

                <div class="billing-items-body">
                    {# Empty State #}
                    {% if form.lines|length == 0 %}
                        <div class="empty">
                            <div class="empty-icon">
                                {{ ux_icon('tabler:file-plus', {width: 32, height: 32}) }}
                            </div>
                            <p class="empty-title">{{ 'invoice.items.empty.title'|trans }}</p>
                            <p class="empty-subtitle text-secondary">{{ 'invoice.items.empty.description'|trans }}</p>
                        </div>
                    {% else %}
                        {# Responsive Line Items - Table on desktop, stacked on mobile via CSS #}
                        <div class="billing-items-list">
                            <div class="billing-items-header-row">
                                <div class="column-description">{{ 'invoice.item.heading.description'|trans }}</div>
                                <div class="column-price">{{ 'invoice.item.heading.price'|trans }}</div>
                                <div class="column-qty">{{ 'invoice.item.heading.qty'|trans }}</div>
                                {% if hasTax %}
                                    <div class="column-tax">{{ 'invoice.item.heading.tax'|trans }}</div>
                                {% endif %}
                                <div class="column-total">{{ 'invoice.item.heading.total'|trans }}</div>
                                <div class="column-actions"></div>
                            </div>

                            {% for index, item in form.lines %}
                                <div class="billing-item-row">
                                    <div class="column-description">
                                        <span class="mobile-label">{{ 'invoice.item.heading.description'|trans }}</span>
                                        {{ form_widget(item.description, {attr: {placeholder: 'invoice.item.description.placeholder'|trans, rows: 2}}) }}
                                        {{ form_errors(item.description) }}
                                    </div>
                                    <div class="column-price">
                                        <span class="mobile-label">{{ 'invoice.item.heading.price'|trans }}</span>
                                        {{ form_widget(item.price) }}
                                        {{ form_errors(item.price) }}
                                    </div>
                                    <div class="column-qty">
                                        <span class="mobile-label">{{ 'invoice.item.heading.qty'|trans }}</span>
                                        {{ form_widget(item.qty) }}
                                        {{ form_errors(item.qty) }}
                                    </div>
                                    {% if hasTax %}
                                        <div class="column-tax">
                                            <span class="mobile-label">{{ 'invoice.item.heading.tax'|trans }}</span>
                                            {{ form_widget(item.tax) }}
                                            {{ form_errors(item.tax) }}
                                        </div>
                                    {% endif %}
                                    <div class="column-total">
                                        <span class="mobile-label">{{ 'invoice.item.heading.total'|trans }}</span>
                                        <span class="item-total-value">{{ item.vars.value.total|formatCurrency(currency) }}</span>
                                    </div>
                                    <div class="column-actions">
                                        {% if form.lines|length > 1 %}
                                            {{ form_widget(item.vars.button_delete, {
                                                label: ux_icon('tabler:trash', {width: 16, height: 16})|raw,
                                                label_html: true,
                                                attr: {class: 'remove-item-btn', title: 'invoice.item.remove'|trans, 'aria-label': 'invoice.item.remove'|trans}
                                            }) }}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Add Item Button #}
                    <div class="add-item-action">
                        {{ form_widget(form.lines.vars.button_add, {
                            label: 'invoice.item.add'|trans,
                            attr: {class: 'add-item-btn btn-sm'}
                        }) }}
                    </div>
                </div>
            </div>

            {# Totals Sidebar #}
            <div class="billing-totals-sidebar">
                <div class="billing-totals-card">
                    <div class="billing-totals-header">
                        <div class="billing-totals-icon">
                            {{ ux_icon('tabler:calculator', {width: 20, height: 20}) }}
                        </div>
                        <h2 class="billing-totals-title">{{ 'invoice.totals.title'|trans }}</h2>
                    </div>

                    <div class="billing-totals-body">
                        <div class="totals-row">
                            <span class="totals-label">{{ 'billing.subtotal'|trans }}</span>
                            <span class="totals-value">{{ dto.baseTotal|formatCurrency(currency) }}</span>
                        </div>

                        {% if hasTax %}
                            <div class="totals-row">
                                <span class="totals-label">{{ 'billing.tax'|trans }}</span>
                                <span class="totals-value">{{ dto.tax|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}

                        <div class="totals-row totals-row-discount">
                            <span class="totals-label">{{ 'billing.discount'|trans }}</span>
                            <span class="totals-value">{{ this.discountAmount|formatCurrency(currency) }}</span>
                        </div>

                        <div class="totals-row totals-row-total">
                            <span class="totals-label">{{ 'billing.total'|trans }}</span>
                            <span class="totals-value">{{ dto.total|formatCurrency(currency) }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Terms & Notes - Collapsible Section #}
        <details class="billing-terms-section"{{ hasTermsOrNotes ? ' open' : '' }}>
            <summary class="terms-summary" aria-label="{{ 'invoice.terms_notes.toggle'|trans }}">
                <span class="terms-summary-icon">
                    {{ ux_icon('tabler:chevron-right', {width: 18, height: 18}) }}
                </span>
                <span class="terms-summary-text">
                    <span class="terms-summary-title">{{ 'invoice.terms_notes.title'|trans }}</span>
                    <span class="badge bg-secondary-lt">{{ 'optional'|trans }}</span>
                </span>
            </summary>
            <div class="terms-content">
                <div class="terms-grid">
                    {{ form_row(form.terms) }}
                    {{ form_row(form.notes) }}
                </div>
            </div>
        </details>

        {# Hidden fields #}
        {{ form_widget(form.total) }}
        {{ form_widget(form.baseTotal) }}
        {{ form_widget(form.tax) }}

        {# Sticky Form Actions #}
        <div class="billing-form-actions">
            <div class="billing-form-actions-inner">
                <a href="{{ path('_invoices_index') }}" class="btn btn-ghost">
                    {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                    {{ 'invoice.save.cancel'|trans }}
                </a>

                <div class="btn-group save-button-group">
                    {% if isEdit %}
                        <button type="button" class="btn btn-primary btn-save-primary" {{ live_action('saveUpdate:prevent') }}>
                            {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                            {{ 'invoice.save.update'|trans }}
                        </button>
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">{{ 'invoice.view.toolbar.toggle_dropdown'|trans }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <button type="button" class="dropdown-item" {{ live_action('savePublish:prevent') }}>
                                    {{ ux_icon('tabler:check', {width: 16, height: 16}) }}
                                    {{ 'invoice.save.publish'|trans }}
                                </button>
                            </li>
                            {% if not is_email_verification_gated() %}
                            <li>
                                <button type="button" class="dropdown-item" {{ live_action('saveSend:prevent') }}>
                                    {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                    {{ 'invoice.save.send'|trans }}
                                </button>
                            </li>
                            {% endif %}
                        </ul>
                    {% else %}
                        <button type="button" class="btn btn-primary btn-save-primary" {{ live_action('saveDraft:prevent') }}>
                            {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                            {{ 'invoice.save.draft'|trans }}
                        </button>
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">{{ 'invoice.view.toolbar.toggle_dropdown'|trans }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <button type="button" class="dropdown-item" {{ live_action('savePublish:prevent') }}>
                                    {{ ux_icon('tabler:check', {width: 16, height: 16}) }}
                                    {{ 'invoice.save.publish'|trans }}
                                </button>
                            </li>
                            {% if not is_email_verification_gated() %}
                            <li>
                                <button type="button" class="dropdown-item" {{ live_action('saveSend:prevent') }}>
                                    {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                    {{ 'invoice.save.send'|trans }}
                                </button>
                            </li>
                            {% endif %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
</div>
