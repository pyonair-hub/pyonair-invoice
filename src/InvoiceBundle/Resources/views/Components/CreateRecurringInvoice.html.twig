<div {{ attributes.defaults({class: 'billing-form-page'}) }}>
    {% set currency = invoice.client ? invoice.client.currency : null %}
    {% set hasTermsOrNotes = invoice.terms or invoice.notes %}

    {{ form_start(form) }}

    <div class="billing-form-container">
        {# Page Header #}
        <div class="billing-form-header">
            <div class="billing-form-header-content">
                <div class="billing-form-icon">
                    {{ ux_icon('tabler:repeat', {width: 28, height: 28}) }}
                </div>
                <div>
                    {% if isEdit %}
                        <h1 class="billing-form-title">{{ 'invoice.recurring.edit.title'|trans }}</h1>
                    {% else %}
                        <h1 class="billing-form-title">{{ 'invoice.recurring.create.title'|trans }}</h1>
                        <p class="billing-form-subtitle">{{ 'invoice.recurring.create.subtitle'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Invoice Details Section (Client + Discount, no dates for recurring) #}
        <div class="billing-details-section">
            <div class="billing-details-grid">
                {# Left Column: Client Selection #}
                <div class="billing-details-left">
                    {# Client Selection #}
                    <div class="client-selection">
                        <div{{ form.client.vars.data is not empty ? ' class="d-none"' }}>
                            {{ form_row(form.client, {attr: {'data-action': 'live#$render'}}) }}
                        </div>
                        {% if form.client.vars.data %}
                            {% include "@SolidInvoiceClient/Ajax/info.html.twig" with {'client': form.client.vars.data, 'form': form} %}
                        {% endif %}
                    </div>
                </div>

                {# Right Column: Discount #}
                <div class="billing-details-right">
                    {{ form_row(form.discount) }}
                </div>
            </div>
        </div>

        {# Main Content: 2-Column Layout #}
        <div class="billing-form-main">
            {# Line Items Section #}
            <div class="billing-items-section">
                <div class="billing-items-header">
                    <div class="billing-items-icon">
                        {{ ux_icon('tabler:list-details', {width: 20, height: 20}) }}
                    </div>
                    <h2 class="billing-items-title">{{ 'invoice.items.title'|trans }}</h2>
                </div>

                <div class="billing-items-body">
                    {# Empty State #}
                    {% if form.lines|length == 0 %}
                        <div class="billing-items-empty">
                            <div class="billing-items-empty-icon">
                                {{ ux_icon('tabler:file-plus', {width: 32, height: 32}) }}
                            </div>
                            <h3 class="billing-items-empty-title">{{ 'invoice.items.empty.title'|trans }}</h3>
                            <p class="billing-items-empty-text">{{ 'invoice.items.empty.description'|trans }}</p>
                        </div>
                    {% else %}
                        {# Responsive Line Items #}
                        <div class="billing-items-list">
                            <div class="billing-items-header-row">
                                <div class="column-description">{{ 'invoice.item.heading.description'|trans }}</div>
                                <div class="column-price">{{ 'invoice.item.heading.price'|trans }}</div>
                                <div class="column-qty">{{ 'invoice.item.heading.qty'|trans }}</div>
                                {% if hasTax %}
                                    <div class="column-tax">{{ 'invoice.item.heading.tax'|trans }}</div>
                                {% endif %}
                                <div class="column-total">{{ 'invoice.item.heading.total'|trans }}</div>
                                <div class="column-actions"></div>
                            </div>

                            {% for index, item in form.lines %}
                                <div class="billing-item-row">
                                    <div class="column-description">
                                        <span class="mobile-label">{{ 'invoice.item.heading.description'|trans }}</span>
                                        {{ form_widget(item.description, {attr: {placeholder: 'invoice.item.description.placeholder'|trans, rows: 2}}) }}
                                        {{ form_errors(item.description) }}
                                    </div>
                                    <div class="column-price">
                                        <span class="mobile-label">{{ 'invoice.item.heading.price'|trans }}</span>
                                        {{ form_widget(item.price) }}
                                        {{ form_errors(item.price) }}
                                    </div>
                                    <div class="column-qty">
                                        <span class="mobile-label">{{ 'invoice.item.heading.qty'|trans }}</span>
                                        {{ form_widget(item.qty) }}
                                        {{ form_errors(item.qty) }}
                                    </div>
                                    {% if hasTax %}
                                        <div class="column-tax">
                                            <span class="mobile-label">{{ 'invoice.item.heading.tax'|trans }}</span>
                                            {{ form_widget(item.tax) }}
                                            {{ form_errors(item.tax) }}
                                        </div>
                                    {% endif %}
                                    <div class="column-total">
                                        <span class="mobile-label">{{ 'invoice.item.heading.total'|trans }}</span>
                                        <span class="item-total-value">{{ item.vars.value.total|formatCurrency(currency) }}</span>
                                    </div>
                                    <div class="column-actions">
                                        {% if form.lines|length > 1 %}
                                            {{ form_widget(item.vars.button_delete, {
                                                label: ux_icon('tabler:trash', {width: 16, height: 16})|raw,
                                                label_html: true,
                                                attr: {class: 'remove-item-btn', title: 'invoice.item.remove'|trans, 'aria-label': 'invoice.item.remove'|trans}
                                            }) }}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Add Item Button #}
                    <div class="add-item-action">
                        {{ form_widget(form.lines.vars.button_add, {
                            label: 'invoice.item.add'|trans,
                            attr: {class: 'add-item-btn btn-sm'}
                        }) }}
                    </div>
                </div>
            </div>

            {# Totals Sidebar #}
            <div class="billing-totals-sidebar">
                <div class="billing-totals-card">
                    <div class="billing-totals-header">
                        <div class="billing-totals-icon">
                            {{ ux_icon('tabler:calculator', {width: 20, height: 20}) }}
                        </div>
                        <h2 class="billing-totals-title">{{ 'invoice.totals.title'|trans }}</h2>
                    </div>

                    <div class="billing-totals-body">
                        <div class="totals-row">
                            <span class="totals-label">{{ 'billing.subtotal'|trans }}</span>
                            <span class="totals-value">{{ invoice.baseTotal|formatCurrency(currency) }}</span>
                        </div>

                        {% if hasTax %}
                            <div class="totals-row">
                                <span class="totals-label">{{ 'billing.tax'|trans }}</span>
                                <span class="totals-value">{{ invoice.tax|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}

                        <div class="totals-row totals-row-discount">
                            <span class="totals-label">{{ 'billing.discount'|trans }}</span>
                            <span class="totals-value">{{ discount(invoice)|formatCurrency(currency) }}</span>
                        </div>

                        <div class="totals-row totals-row-total">
                            <span class="totals-label">{{ 'billing.total'|trans }}</span>
                            <span class="totals-value">{{ invoice.total|formatCurrency(currency) }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Recurring Schedule - Always Visible Section #}
        <section class="recurring-schedule-section">
            <div class="section-header">
                <div class="section-header-icon">
                    {{ ux_icon('tabler:repeat', {width: 20, height: 20}) }}
                </div>
                <div class="section-header-content">
                    <h3 class="section-title">{{ 'invoice.recurring.schedule.title'|trans }}</h3>
                    <p class="section-description">{{ 'invoice.recurring.schedule.description'|trans }}</p>
                </div>
            </div>

            <div class="recurring-schedule-content">
                {# Display current frequency #}
                {% set frequency = recurring_frequency(invoice.recurringOptions) %}
                {% if frequency is not empty %}
                    <div class="recurring-frequency-display">
                        <div class="recurring-frequency-icon">
                            {{ ux_icon('tabler:calendar-repeat', {width: 20, height: 20}) }}
                        </div>
                        <div class="recurring-frequency-text">
                            <strong>{{ frequency }}</strong>
                        </div>
                    </div>
                {% endif %}

                {# Start Date #}
                <div class="mb-3">
                    {{ form_row(form.date_start) }}
                </div>

                {# Recurring Options - Let DynamicFormBuilder handle all fields #}
                <div class="mb-3 recurring-options-wrapper">
                    {{ form_row(form.recurringOptions) }}
                </div>

                {# Help Text for Variables - Collapsible Info Box #}
                <details class="recurring-variables-help">
                    <summary class="variables-summary">
                        {{ ux_icon('tabler:info-circle', {width: 16, height: 16}) }}
                        <span>{{ 'invoice.recurring.variables.help_button'|trans }}</span>
                    </summary>
                    <div class="variables-content">
                        <p class="variables-description">{{ 'invoice.recurring.variables.text'|trans }}</p>
                        <ul class="variables-list">
                            <li>
                                <code>{day}</code>
                                <span class="variable-description">{{ 'invoice.recurring.variables.day'|trans }}</span>
                            </li>
                            <li>
                                <code>{day_name}</code>
                                <span class="variable-description">{{ 'invoice.recurring.variables.day_name'|trans }}</span>
                            </li>
                            <li>
                                <code>{month}</code>
                                <span class="variable-description">{{ 'invoice.recurring.variables.month'|trans({"%month%": 'now'|date('F')}) }}</span>
                            </li>
                            <li>
                                <code>{year}</code>
                                <span class="variable-description">{{ 'invoice.recurring.variables.year'|trans({"%year%": 'now'|date('Y')}) }}</span>
                            </li>
                        </ul>
                        <div class="variable-example">
                            <strong>{{ 'invoice.recurring.variables.example_label'|trans }}:</strong>
                            <span class="example-text">"{{ 'invoice.recurring.variables.example_input'|trans }}" → "{{ 'invoice.recurring.variables.example_output'|trans({"%month%": 'now'|date('F')}) }}"</span>
                        </div>
                    </div>
                </details>
            </div>
        </section>

        {# Terms & Notes - Collapsible Section #}
        <details class="billing-terms-section"{{ hasTermsOrNotes ? ' open' : '' }}>
            <summary class="terms-summary" aria-label="{{ 'invoice.terms_notes.toggle'|trans }}">
                <span class="terms-summary-icon">
                    {{ ux_icon('tabler:chevron-right', {width: 18, height: 18}) }}
                </span>
                <span class="terms-summary-text">
                    <span class="terms-summary-title">{{ 'invoice.terms_notes.title'|trans }}</span>
                    <span class="terms-summary-badge">{{ 'optional'|trans }}</span>
                </span>
            </summary>
            <div class="terms-content">
                <div class="terms-grid">
                    {{ form_row(form.terms) }}
                    {{ form_row(form.notes) }}
                </div>
            </div>
        </details>

        {# Hidden fields #}
        {{ form_widget(form.total) }}
        {{ form_widget(form.baseTotal) }}
        {{ form_widget(form.tax) }}

        {# Sticky Form Actions #}
        <div class="billing-form-actions">
            <div class="billing-form-actions-inner">
                <a href="{{ path('_invoices_index_recurring') }}" class="btn btn-ghost">
                    {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                    {{ 'invoice.save.cancel'|trans }}
                </a>

                <div class="btn-group save-button-group">
                    {% if isEdit %}
                        <button type="submit" class="btn btn-primary btn-save-primary" name="save" value="save">
                            {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                            {{ 'invoice.save.update'|trans }}
                        </button>
                    {% else %}
                        <button type="submit" class="btn btn-primary btn-save-primary" name="save" value="save">
                            {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                            {{ 'invoice.save.draft'|trans }}
                        </button>
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">{{ 'invoice.view.toolbar.toggle_dropdown'|trans }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <button type="submit" class="dropdown-item" name="save" value="publish">
                                    {{ ux_icon('tabler:check', {width: 16, height: 16}) }}
                                    {{ 'invoice.recurring.activate_start'|trans }}
                                </button>
                            </li>
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
</div>
