{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}
    {{ ux_icon('tabler:file-invoice', {width: 24, height: 24, class: 'me-2'}) }}{{ (recurring ? "invoice.list.recurring_title" : "invoice.list.title")|trans }}
{% endblock title %}

{% block heading %}
    {% if recurring %}
        <a class="btn btn-primary" href="{{ path("_invoices_create_recurring") }}">
            {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
            {{ "invoice.action.create_recurring"|trans }}
        </a>
    {% else %}
        <a class="btn btn-primary" href="{{ path("_invoices_create") }}">
            {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
            {{ "invoice.action.create"|trans }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {% if recurring %}
        {# Recurring Invoices Stats Row #}
        <div class="row row-deck row-cards mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-primary text-white avatar">
                                    {{ ux_icon('tabler:repeat', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ totalActiveRecurring }}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.active_recurring'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-info text-white avatar">
                                    {{ ux_icon('tabler:calendar-event', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ upcomingIn7Days }}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.upcoming_7_days'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-warning text-white avatar">
                                    {{ ux_icon('tabler:list-check', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ 'invoice.stats.status_format'|trans({
                                        '%active%': activeCount,
                                        '%draft%': draftCount,
                                        '%paused%': pausedCount
                                    }) }}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.status_breakdown'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-success text-white avatar">
                                    {{ ux_icon('tabler:file-invoice', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ totalGeneratedInvoices }}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.total_generated'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Recurring Invoice List Card with Tabs #}
        <twig:Ui:Card>
            <twig:block name="header">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs" role="tablist" aria-label="{{ 'invoice.tabs.label'|trans }}">
                        <li class="nav-item" role="presentation">
                            <a href="{{ path('_invoices_index_recurring') }}" class="nav-link{{ not isArchived and not isCompleted ? ' active' : '' }}" role="tab" aria-selected="{{ not isArchived and not isCompleted ? 'true' : 'false' }}">
                                {{ ux_icon('tabler:repeat', {width: 16, height: 16}) }}
                                {{ 'invoice.tabs.recurring_active'|trans }}
                                <span class="badge bg-primary-lt ms-2">{{ totalActiveRecurring }}</span>
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a href="{{ path('_invoices_index_recurring', {completed: 1}) }}" class="nav-link{{ isCompleted ? ' active' : '' }}" role="tab" aria-selected="{{ isCompleted ? 'true' : 'false' }}">
                                {{ ux_icon('tabler:check', {width: 16, height: 16}) }}
                                {{ 'invoice.tabs.recurring_completed'|trans }}
                                <span class="badge bg-success-lt ms-2">{{ completeCount }}</span>
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a href="{{ path('_invoices_index_recurring', {archived: 1}) }}" class="nav-link{{ isArchived ? ' active' : '' }}" role="tab" aria-selected="{{ isArchived ? 'true' : 'false' }}">
                                {{ ux_icon('tabler:archive', {width: 16, height: 16}) }}
                                {{ 'invoice.tabs.recurring_archived'|trans }}
                                <span class="badge bg-secondary-lt ms-2">{{ totalArchivedRecurring }}</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </twig:block>

            {% if isArchived %}
                <twig:DataGrid name="archived_recurring_invoice_grid" />
            {% elseif isCompleted %}
                <twig:DataGrid name="completed_recurring_invoice_grid" />
            {% else %}
                <twig:DataGrid name="recurring_invoice_grid" />
            {% endif %}
        </twig:Ui:Card>
    {% else %}
        {# Stats Row #}
        <div class="row row-deck row-cards mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-primary text-white avatar">
                                    {{ ux_icon('tabler:file-invoice', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ totalActiveInvoices }}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.total_invoices'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-warning text-white avatar">
                                    {{ ux_icon('tabler:clock', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {{ pendingCount }}
                                    {% if overdueCount > 0 %}
                                        <span class="text-danger ms-1">({{ overdueCount }} {{ 'invoice.stats.overdue'|trans }})</span>
                                    {% endif %}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.pending_invoices'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-success text-white avatar">
                                    {{ ux_icon('tabler:cash', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {% for currency, amount in total_income %}
                                        {{ amount|formatCurrency(currency) }}{% if not loop.last %}<br>{% endif %}
                                    {% else %}
                                        {{ 0|formatCurrency }}
                                    {% endfor %}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.total_income'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-danger text-white avatar">
                                    {{ ux_icon('tabler:currency-dollar', {width: 24, height: 24}) }}
                                </span>
                            </div>
                            <div class="col">
                                <div class="fw-medium">
                                    {% for currency, amount in total_outstanding %}
                                        {{ amount|formatCurrency(currency) }}{% if not loop.last %}<br>{% endif %}
                                    {% else %}
                                        {{ 0|formatCurrency }}
                                    {% endfor %}
                                </div>
                                <div class="text-secondary">
                                    {{ 'invoice.stats.outstanding_balance'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Invoice List Card #}
        <twig:Ui:Card>
            <twig:block name="header">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs" role="tablist" aria-label="{{ 'invoice.tabs.label'|trans }}">
                        <li class="nav-item" role="presentation">
                            <a href="{{ path('_invoices_index') }}" class="nav-link{{ not isArchived ? ' active' : '' }}" role="tab" aria-selected="{{ not isArchived ? 'true' : 'false' }}">
                                {{ ux_icon('tabler:file-invoice', {width: 16, height: 16}) }}
                                {{ 'invoice.tabs.active'|trans }}
                                <span class="badge bg-primary-lt ms-2">{{ totalActiveInvoices }}</span>
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a href="{{ path('_invoices_index', {archived: 1}) }}" class="nav-link{{ isArchived ? ' active' : '' }}" role="tab" aria-selected="{{ isArchived ? 'true' : 'false' }}">
                                {{ ux_icon('tabler:archive', {width: 16, height: 16}) }}
                                {{ 'invoice.tabs.archived'|trans }}
                                <span class="badge bg-secondary-lt ms-2">{{ totalArchivedInvoices }}</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </twig:block>

            {% if isArchived %}
                <twig:DataGrid name="archived_invoice_grid" />
            {% else %}
                <twig:DataGrid name="invoice_grid" />
            {% endif %}
        </twig:Ui:Card>
    {% endif %}
{% endblock content %}

