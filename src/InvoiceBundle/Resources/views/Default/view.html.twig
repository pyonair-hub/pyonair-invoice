{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block page_title %}
    {{ "invoice.title"|trans({"%id%" : invoice.invoiceId}) }}
{% endblock page_title %}

{% block content %}
{% set currency = invoice.client.currency %}
<div class="doc-view-page">
    <div class="doc-view-header no-print">
        <div class="doc-view-header-left">
            <div class="doc-view-icon">
                {{ ux_icon('tabler:file-invoice', {width: 32, height: 32}) }}
            </div>
            <div class="doc-view-title-group">
                <h1 class="doc-view-title">{{ "invoice.title"|trans({"%id%" : invoice.invoiceId}) }}</h1>
                <div class="doc-view-meta">
                    {{ invoice_label(invoice.status) }}
                    {% if invoice.due is not empty %}
                        <span class="doc-view-meta-item">
                            {{ ux_icon('tabler:calendar', {width: 14, height: 14}) }}
                            {{ 'invoice.due_date'|trans }}: {{ invoice.due|date('M d, Y') }}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="doc-view-header-actions">
            {# Always available actions #}
            <div class="doc-view-utility-actions">
                <button type="button" onclick="window.print()" class="btn btn-ghost btn-icon" title="{{ 'invoice.action.print'|trans }}">
                    {{ ux_icon('tabler:printer', {width: 20, height: 20}) }}
                </button>
                {% if can_print_pdf() %}
                    <a href="{{ path('_invoices_view', {'id': invoice.id, '_format': 'pdf'}) }}" target="_blank" class="btn btn-ghost btn-icon" title="{{ 'invoice.action.pdf'|trans }}">
                        {{ ux_icon('tabler:file-type-pdf', {width: 20, height: 20}) }}
                    </a>
                {% endif %}

                {# More Actions Dropdown #}
                <div class="dropdown">
                    <button class="btn btn-ghost btn-icon" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="{{ 'invoice.view.toolbar.more_actions'|trans }}">
                        {{ ux_icon('tabler:dots-vertical', {width: 20, height: 20}) }}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        {% if invoice.quote is not null and invoice.quote.valid %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_quotes_view', {'id' : invoice.quote.id}) }}">
                                    {{ ux_icon('tabler:file-text', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.view_quote"|trans }}
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        {% endif %}

                        <li>
                            <a class="dropdown-item" href="{{ path('_invoices_clone', {'id' : invoice.id}) }}">
                                {{ ux_icon('tabler:copy', {width: 16, height: 16}) }}
                                {{ "invoice.view.toolbar.clone"|trans }}
                            </a>
                        </li>

                        {% if invoice.status in [enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Pending, enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue] and invoice.users|length > 0 %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#send-reminder-modal">
                                    {{ ux_icon('tabler:bell', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.send_reminder"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(invoice, 'edit') %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_invoices_edit', {'id' : invoice.id}) }}">
                                    {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.edit"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(invoice, 'reopen') %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_action_invoice', {'action' : 'reopen', 'id' : invoice.id}) }}">
                                    {{ ux_icon('tabler:refresh', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.reopen"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(invoice, 'archive') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('_action_invoice', {'action' : 'archive', 'id' : invoice.id}) }}">
                                    {{ ux_icon('tabler:archive', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.archive"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(invoice, 'cancel') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('_action_invoice', {'action' : 'cancel', 'id' : invoice.id}) }}">
                                    {{ ux_icon('tabler:x', {width: 16, height: 16}) }}
                                    {{ "invoice.view.toolbar.cancel"|trans }}
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            {# Hero Action - Changes based on invoice state #}
            {% if workflow_can(invoice, 'pay') %}
                <a href="{{ path('_payments_create', {'uuid' : invoice.uuid}) }}" class="btn btn-primary btn-hero {{ invoice.status == enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue ? 'btn-hero-urgent' : '' }}">
                    {{ ux_icon('tabler:credit-card', {width: 18, height: 18}) }}
                    {{ "invoice.view.toolbar.pay_now"|trans }}
                </a>
                {% if is_email_verification_gated() %}
                    <span class="d-inline-block" tabindex="0"
                          data-bs-toggle="tooltip"
                          title="{{ email_verification_message('sending this invoice') }}">
                        <button type="button" class="btn btn-primary btn-hero disabled {{ invoice.status == enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue ? 'btn-hero-urgent' : '' }}" disabled style="pointer-events: none;">
                            {{ ux_icon('tabler:send', {width: 18, height: 18}) }}
                            {{ "invoice.view.toolbar.send"|trans }}
                        </button>
                    </span>
                {% else %}
                    <a href="{{ path('_send_invoice', {'id' : invoice.id}) }}" class="btn btn-primary btn-hero {{ invoice.status == enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue ? 'btn-hero-urgent' : '' }}">
                        {{ ux_icon('tabler:send', {width: 18, height: 18}) }}
                        {{ "invoice.view.toolbar.send"|trans }}
                    </a>
                {% endif %}
            {% elseif workflow_can(invoice, 'accept') %}
                <div class="btn-group">
                    <a href="{{ path('_action_invoice', {'action' : 'accept', 'id' : invoice.id}) }}" class="btn btn-primary btn-hero">
                        {{ ux_icon('tabler:check', {width: 18, height: 18}) }}
                        {{ 'invoice.save.publish'|trans }}
                    </a>
                    <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="visually-hidden">{{ 'invoice.view.toolbar.toggle_dropdown'|trans }}</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            {% if is_email_verification_gated() %}
                                <span class="d-block" tabindex="0"
                                      data-bs-toggle="tooltip"
                                      title="{{ email_verification_message('sending this invoice') }}">
                                    <button type="button" class="dropdown-item disabled" disabled style="pointer-events: none;">
                                        {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                        {{ 'invoice.view.toolbar.publish_and_send'|trans }}
                                    </button>
                                </span>
                            {% else %}
                                <a class="dropdown-item" href="{{ path('_send_invoice', {'id' : invoice.id}) }}">
                                    {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                    {{ 'invoice.view.toolbar.publish_and_send'|trans }}
                                </a>
                            {% endif %}
                        </li>
                    </ul>
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT - Invoice Document + Sidebar
    ═══════════════════════════════════════════════════════════════════════ #}
    <div class="doc-view-content">
        {# Invoice Document (Main Area) #}
        <div class="doc-view-document">
            <div class="doc-card">
                {# Document Header - From/To #}
                <div class="doc-header-from-to">
                    <div class="doc-party doc-party-from">
                        <div class="doc-party-label">{{ 'invoice.from'|trans }}</div>
                        <h3 class="doc-party-name">{{ company_name() }}</h3>

                        {% set vatNumber = setting('system/company/vat_number') %}
                        {% if vatNumber is not empty %}
                            <div class="doc-party-detail">
                                <span class="detail-label">{{ 'tax.vat_number'|trans }}</span>
                                <span class="detail-value">{{ vatNumber }}</span>
                            </div>
                        {% endif %}

                        {% set email = setting('system/company/contact_details/email') %}
                        {% if email is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:mail', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ email }}</span>
                            </div>
                        {% endif %}

                        {% set phoneNumber = setting('system/company/contact_details/phone_number') %}
                        {% if phoneNumber is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:phone', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ phoneNumber }}</span>
                            </div>
                        {% endif %}

                        {% set address = setting('system/company/contact_details/address', null, true) %}
                        {% if address is not null and address|filter(v => v) is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:map-pin', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ address(address)|replace({"\n": ", "}) }}</span>
                            </div>
                        {% endif %}
                    </div>

                    <div class="doc-party doc-party-to">
                        <div class="doc-party-label">{{ 'invoice.to'|trans }}</div>
                        <h3 class="doc-party-name">{{ invoice.client }}</h3>

                        {% if invoice.client.website is not empty %}
                            <div class="doc-party-detail">
                            {% set website_url = invoice.client.website starts with 'http://' or invoice.client.website starts with 'https://' ? invoice.client.website : 'https://' ~ invoice.client.website %}
                                {{ ux_icon('tabler:world', {width: 14, height: 14}) }}
                                <a href="{{ website_url }}" class="detail-value" rel="external noopener" target="_blank">
                                    <span>{{ invoice.client.website }}</span>
                                    {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                                </a>
                            </div>
                        {% endif %}

                        {% if invoice.client.vatNumber is not empty %}
                            <div class="doc-party-detail">
                                <span class="detail-label">{{ 'tax.vat_number'|trans }}</span>
                                <span class="detail-value">{{ invoice.client.vatNumber }}</span>
                            </div>
                        {% endif %}

                        {% for address in invoice.client.addresses %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:map-pin', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ address|replace({"\n": ", "}) }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# Line Items Table #}
                <div class="doc-items">
                    <table class="doc-items-table">
                        <thead>
                            <tr>
                                <th class="column-description">{{ 'invoice.item.heading.description'|trans }}</th>
                                <th class="column-price">{{ 'invoice.item.heading.price'|trans }}</th>
                                <th class="column-qty">{{ 'invoice.item.heading.qty'|trans }}</th>
                                {% if invoice.tax.positive %}
                                    <th class="column-tax">{{ 'invoice.item.heading.tax'|trans }}</th>
                                {% endif %}
                                <th class="column-total">{{ 'invoice.item.heading.total'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in invoice.lines %}
                                <tr>
                                    <td class="column-description" data-label="{{ 'invoice.item.heading.description'|trans }}">{{ item.description|nl2br }}</td>
                                    <td class="column-price" data-label="{{ 'invoice.item.heading.price'|trans }}">{{ item.price|formatCurrency(currency) }}</td>
                                    <td class="column-qty" data-label="{{ 'invoice.item.heading.qty'|trans }}">{{ item.qty }}</td>
                                    {% if invoice.tax.positive %}
                                        <td class="column-tax" data-label="{{ 'invoice.item.heading.tax'|trans }}">{{ item.tax }}</td>
                                    {% endif %}
                                    <td class="column-total" data-label="{{ 'invoice.item.heading.total'|trans }}">{{ item.total|formatCurrency(currency) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Totals Section #}
                <div class="doc-totals">
                    <div class="doc-totals-grid">
                        <div class="totals-row">
                            <span class="totals-label">{{ 'invoice.subtotal'|trans }}</span>
                            <span class="totals-value">{{ invoice.baseTotal|formatCurrency(currency) }}</span>
                        </div>

                        {% if invoice.tax.positive %}
                            <div class="totals-row">
                                <span class="totals-label">{{ 'invoice.tax'|trans }}</span>
                                <span class="totals-value">{{ invoice.tax|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}

                        {% if invoice.hasDiscount %}
                            <div class="totals-row totals-row-discount">
                                <span class="totals-label">{{ 'invoice.discount'|trans }}</span>
                                <span class="totals-value">-{{ discount(invoice)|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}

                        {# Show partial payments in totals #}
                        {% if invoice.payments|length > 0 and not invoice.balance.isZero %}
                            {% for payment in invoice.payments|filter((v) => v.status == enum('SolidInvoice\\PaymentBundle\\Enum\\PaymentStatus').Captured) %}
                                <div class="totals-row totals-row-payment">
                                    <span class="totals-label">
                                        {{ 'invoice.payment.label'|trans }}: {{ payment.method.name }}
                                    </span>
                                    <span class="totals-value">-{{ payment.amount.amount|formatCurrency(currency) }}</span>
                                </div>
                            {% endfor %}
                        {% endif %}

                        {% set hasOutstandingBalance = invoice.payments|length > 0 and not invoice.balance.isZero %}
                        <div class="totals-row totals-row-final">
                            <span class="totals-label">
                                {{ hasOutstandingBalance ? 'invoice.balance'|trans : 'invoice.total'|trans }}
                            </span>
                            <span class="totals-value">
                                {{ (hasOutstandingBalance ? invoice.balance : invoice.total)|formatCurrency(currency) }}
                            </span>
                        </div>
                    </div>
                </div>

                {# Terms & Notes #}
                {% if invoice.terms is not empty or invoice.notes is not empty %}
                    <div class="doc-footer">
                        {% if invoice.terms is not empty %}
                            <div class="doc-footer-section">
                                <h4 class="doc-footer-title">{{ 'invoice.terms'|trans }}</h4>
                                <p class="doc-footer-text">{{ invoice.terms|nl2br }}</p>
                            </div>
                        {% endif %}

                        {% if invoice.notes is not empty %}
                            <div class="doc-footer-section no-print">
                                <h4 class="doc-footer-title">{{ 'invoice.notes'|trans }}</h4>
                                <p class="doc-footer-text">{{ invoice.notes|nl2br }}</p>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Sidebar #}
        <div class="doc-view-sidebar no-print">
            {# Client Card #}
            <div class="doc-sidebar-card">
                <div class="doc-sidebar-card-header">
                    <div class="doc-sidebar-card-icon">
                        {{ ux_icon('tabler:building', {width: 18, height: 18}) }}
                    </div>
                    <h3 class="doc-sidebar-card-title">{{ 'invoice.client.title'|trans }}</h3>
                </div>
                <div class="doc-sidebar-card-body">
                    <div class="client-info">
                        <a href="{{ path('_clients_view', {'id': invoice.client.id}) }}" class="client-name">
                            {{ invoice.client }}
                        </a>

                        {% if invoice.users|length > 0 %}
                            <div class="client-contacts">
                                {% for user in invoice.users %}
                                    <div class="client-contact">
                                        <div class="contact-name">{{ user }}</div>
                                        <div class="contact-email">
                                            {{ ux_icon('tabler:mail', {width: 12, height: 12}) }}
                                            {{ user.email }}
                                        </div>
                                        {% for info in user.additionalContactDetails %}
                                            <div class="contact-detail">
                                                {{ info.type|title }}: {{ info.value }}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Invoice Summary Card #}
            <div class="doc-sidebar-card">
                <div class="doc-sidebar-card-header">
                    <div class="doc-sidebar-card-icon">
                        {{ ux_icon('tabler:receipt', {width: 18, height: 18}) }}
                    </div>
                    <h3 class="doc-sidebar-card-title">{{ 'invoice.summary'|trans }}</h3>
                </div>
                <div class="doc-sidebar-card-body">
                    <div class="doc-summary-grid">
                        <div class="summary-item">
                            <span class="summary-label">{{ 'invoice.status'|trans }}</span>
                            <span class="summary-value">{{ invoice_label(invoice.status) }}</span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">{{ 'invoice.total'|trans }}</span>
                            <span class="summary-value summary-value-amount">{{ invoice.total|formatCurrency(currency) }}</span>
                        </div>
                        {% if invoice.payments|length > 0 and not invoice.balance.isZero %}
                            <div class="summary-item">
                                <span class="summary-label">{{ 'invoice.balance'|trans }}</span>
                                <span class="summary-value summary-value-balance">{{ invoice.balance|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}
                        <div class="summary-item">
                            <span class="summary-label">{{ 'invoice.date'|trans }}</span>
                            <span class="summary-value">{{ invoice.invoiceDate|date('M d, Y') }}</span>
                        </div>
                        {% if invoice.due is not empty %}
                            <div class="summary-item {{ invoice.status == enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue ? 'summary-item-overdue' : '' }}">
                                <span class="summary-label">{{ 'invoice.due_date'|trans }}</span>
                                <span class="summary-value">{{ invoice.due|date('M d, Y') }}</span>
                            </div>
                        {% endif %}
                        {% if invoice.paidDate is not empty %}
                            <div class="summary-item summary-item-paid">
                                <span class="summary-label">{{ 'invoice.paid_date'|trans }}</span>
                                <span class="summary-value">{{ invoice.paidDate|date('M d, Y') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Payments Card (if any) #}
            {% if payments|length > 0 %}
                <div class="doc-sidebar-card">
                    <div class="doc-sidebar-card-header">
                        <div class="doc-sidebar-card-icon">
                            {{ ux_icon('tabler:credit-card', {width: 18, height: 18}) }}
                        </div>
                        <h3 class="doc-sidebar-card-title">{{ 'invoice.view.payments'|trans }}</h3>
                    </div>
                    <div class="doc-sidebar-card-body">
                        <div class="payments-list">
                            {% for payment in payments %}
                                <div class="payment-card {{ payment.status == enum('SolidInvoice\\PaymentBundle\\Enum\\PaymentStatus').Captured ? 'payment-card-captured' : '' }}">
                                    <div class="payment-card-header">
                                        <div class="payment-amount">{{ payment.totalAmount|formatCurrency(currency) }}</div>
                                        <div class="payment-status">{{ payment_label(payment.status) }}</div>
                                    </div>
                                    <div class="payment-card-body">
                                        {% if payment.method is not empty %}
                                            <div class="payment-method">
                                                {{ ux_icon('tabler:credit-card', {width: 14, height: 14}) }}
                                                {{ payment.method }}
                                            </div>
                                        {% endif %}
                                        {% if payment.completed is not empty %}
                                            <div class="payment-date">
                                                {{ ux_icon('tabler:calendar', {width: 14, height: 14}) }}
                                                {{ payment.completed|date('M d, Y') }}
                                            </div>
                                        {% endif %}
                                        {% if payment.message is not empty %}
                                            <div class="payment-message">{{ payment.message }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Related Quote Card (if exists) #}
            {% if invoice.quote is not null and invoice.quote.valid %}
                <div class="doc-sidebar-card doc-sidebar-card-muted">
                    <div class="doc-sidebar-card-header">
                        <div class="doc-sidebar-card-icon">
                            {{ ux_icon('tabler:file-text', {width: 18, height: 18}) }}
                        </div>
                        <h3 class="doc-sidebar-card-title">{{ 'invoice.view.related_quote'|trans }}</h3>
                    </div>
                    <div class="doc-sidebar-card-body">
                        <a href="{{ path('_quotes_view', {'id' : invoice.quote.id}) }}" class="related-quote-link">
                            {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                            {{ 'quote.title'|trans({'%id%': invoice.quote.quoteId}) }}
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════════════
       SEND REMINDER CONFIRMATION MODAL
    ═══════════════════════════════════════════════════════════════════════ #}
    {% if invoice.status in [enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Pending, enum('SolidInvoice\\InvoiceBundle\\Enum\\InvoiceStatus').Overdue] and invoice.users|length > 0 %}
        <twig:Ui:Modal id="send-reminder-modal" title="{{ 'invoice.modal.send_reminder.title'|trans }}" :centered="true">
            <div class="text-center py-3">
                <div class="mb-3">
                    {{ ux_icon('tabler:bell', {width: 48, height: 48, class: 'text-primary'}) }}
                </div>
                <h3>{{ 'invoice.modal.send_reminder.heading'|trans }}</h3>
                <p class="text-muted">{{ 'invoice.modal.send_reminder.message'|trans({'%invoice_id%': invoice.invoiceId}) }}</p>

                {% if invoice.users|length > 0 %}
                    <div class="mt-3">
                        <p class="text-sm text-muted mb-2">{{ 'invoice.modal.send_reminder.recipients'|trans }}</p>
                        <div class="d-flex flex-column gap-1 align-items-center">
                            {% for user in invoice.users %}
                                <div class="text-sm">
                                    {{ ux_icon('tabler:mail', {width: 14, height: 14}) }}
                                    {{ user.email }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>

            <twig:block name="footer">
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">{{ 'invoice.view.toolbar.cancel'|trans }}</button>
                <form method="post" action="{{ path('_send_manual_reminder', {'id': invoice.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('send_manual_reminder') }}">
                    <button type="submit" class="btn btn-primary">
                        {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                        {{ 'invoice.modal.send_reminder.confirm'|trans }}
                    </button>
                </form>
            </twig:block>
        </twig:Ui:Modal>
    {% endif %}
</div>
{% endblock content %}
