{% extends "@SolidInvoiceCore/Layout/Email/notification.html.twig" %}
{% import "@SolidInvoiceCore/Layout/Email/components.html.twig" as email %}

{%- block title -%}
    Payment Reminder
{%- endblock -%}

{%- block content -%}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #0891b2; font-size: 18px; font-weight: 600; line-height: 1.5; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    📋 Invoice Payment Reminder
                </p>
                <p style="color: #1e293b; font-size: 16px; line-height: 1.5; margin: 0 0 24px 0; Margin: 0 0 24px 0;">
                    This is a friendly reminder about invoice <strong>{{ invoice.invoiceId }}</strong>. We kindly ask you to review the invoice details below and arrange payment at your earliest convenience.
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('sm') }}

    {# Invoice details #}
    {{ email.info_row('Invoice Number', invoice.invoiceId) }}

    {% if invoice.invoiceDate %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Invoice Date', invoice.invoiceDate|date('Y-m-d')) }}
    {% endif %}

    {% if invoice.due %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Due Date', invoice.due|date('Y-m-d')) }}
    {% endif %}

    {% if invoice.balance %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Amount Due', invoice.balance|formatCurrency(invoice.client.currency), true) }}
    {% endif %}

    {{ email.divider('md') }}

    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #475569; font-size: 14px; line-height: 1.5; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    Thank you for your business. We appreciate your prompt attention to this invoice.
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('sm') }}

    {# View/Pay button #}
    {{ email.button('View Invoice & Pay', url("_view_invoice_external", {"uuid" : invoice.uuid}), 'primary', 'large') }}

    {{ email.spacer('md') }}

    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #64748b; font-size: 13px; line-height: 1.5; margin: 0; Margin: 0;">
                    If you have any questions or concerns about this invoice, please don't hesitate to contact us.
                </p>
            </columns>
        </row>
    {% endapply %}
{%- endblock -%}
