{% extends "@SolidInvoiceCore/Layout/Email/notification.html.twig" %}
{% import "@SolidInvoiceCore/Layout/Email/components.html.twig" as email %}

{%- block title -%}
    Manual Follow-up Required
{%- endblock -%}

{%- block content -%}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #dc2626; font-size: 18px; font-weight: 600; line-height: 1.5; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    🔔 Final Reminder Sent - Manual Follow-up Required
                </p>
                <p style="color: #1e293b; font-size: 16px; line-height: 1.5; margin: 0 0 24px 0; Margin: 0 0 24px 0;">
                    The final automated payment reminder has been sent for invoice <strong>{{ invoice.invoiceId }}</strong>{% if days_overdue is defined and days_overdue is not null %}, which is now {{ days_overdue }} days overdue{% endif %}. All scheduled reminders are complete. Manual follow-up is recommended to resolve this outstanding payment.
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('sm') }}

    {# Invoice details #}
    {{ email.info_row('Invoice Number', invoice.invoiceId) }}

    {% if invoice.client %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Client', invoice.client.name) }}
    {% endif %}

    {% if invoice.due %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Due Date', invoice.due|date('Y-m-d')) }}
    {% endif %}

    {% if days_overdue %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Days Overdue', days_overdue, true) }}
    {% endif %}

    {% if invoice.balance %}
        {{ email.spacer('xs') }}
        {{ email.info_row('Outstanding Amount', invoice.balance|formatCurrency(invoice.client.currency), true) }}
    {% endif %}

    {{ email.divider('md') }}

    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #475569; font-size: 14px; line-height: 1.5; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    <strong>Recommended Actions:</strong>
                </p>
                <ul style="color: #475569; font-size: 14px; line-height: 1.6; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    <li>Contact the client directly via phone or email</li>
                    <li>Review the client's payment history and account status</li>
                    <li>Consider setting up a payment plan if needed</li>
                    <li>Evaluate whether further services should be provided</li>
                </ul>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('sm') }}

    {# View invoice button #}
    {{ email.button('View Invoice Details', url("_view_invoice", {"id" : invoice.id}), 'primary', 'large') }}

    {{ email.spacer('md') }}

    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #64748b; font-size: 13px; line-height: 1.5; margin: 0; Margin: 0;">
                    This is an automated notification. No further reminder emails will be sent to the client for this invoice unless manually triggered.
                </p>
            </columns>
        </row>
    {% endapply %}
{%- endblock -%}
