{#
 # Editorial — magazine-like premium feel, italic display serif,
 # I./II./III. section markers.
 #}
{% extends '@SolidInvoiceInvoice/Templates/_pdf_base.html.twig' %}
{% import '@SolidInvoiceInvoice/Templates/_macros.html.twig' as inv %}

{% set currency = invoice.client.currency %}

{% block extra_styles %}
    body { font-family: Georgia, 'Times New Roman', serif; color: #2a2a2a; }
    .editorial-marker { font-style: italic; font-size: 11pt; color: #94704a; letter-spacing: 1px; }
{% endblock %}

{% block body %}
<div style="border-bottom: 1px solid #2a2a2a; padding-bottom: 12px; margin-bottom: 28px;">
    <table cellpadding="0" cellspacing="0" style="width: 100%;">
        <tr>
            <td style="vertical-align: bottom;">
                <div style="font-size: 9pt; letter-spacing: 4px; text-transform: uppercase; color: #94704a;">{{ 'invoice.template.editorial.heading'|trans }}</div>
                <div style="font-style: italic; font-size: 32pt; color: #1a1a1a; line-height: 1.0;">{{ 'invoice.number_prefix'|trans }} {{ invoice.invoiceId }}</div>
            </td>
            <td style="vertical-align: bottom; text-align: right;">
                <div style="font-style: italic; font-size: 14pt; color: #2a2a2a;">{{ company_name() }}</div>
                <div style="font-size: 9pt; color: #6b6b6b;">{{ invoice.invoiceDate|date('F j, Y') }}</div>
            </td>
        </tr>
    </table>
</div>

<table cellpadding="0" cellspacing="0" style="width: 100%; margin-bottom: 28px;">
    <tr>
        <td style="width: 8%; vertical-align: top;"><span class="editorial-marker">I.</span></td>
        <td style="width: 46%; vertical-align: top;">{{ inv.from_block() }}</td>
        <td style="width: 8%; vertical-align: top;"><span class="editorial-marker">II.</span></td>
        <td style="width: 38%; vertical-align: top;">{{ inv.bill_to_block(invoice) }}</td>
    </tr>
</table>

<div class="editorial-marker" style="margin-bottom: 12px;">III. {{ 'invoice.item.heading.description'|trans }}</div>
<table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; margin-bottom: 28px;">
    {% for line in invoice.lines %}
        <tr>
            <td style="padding: 14px 0; font-size: 11pt; color: #1a1a1a; border-bottom: 1px solid #e8dcc4; vertical-align: top;">
                <em>{{ line.description|nl2br }}</em>
                <div style="font-size: 9pt; color: #6b6b6b; margin-top: 2px;">{{ line.qty }} × {{ line.price|formatCurrency(currency) }}</div>
            </td>
            <td style="padding: 14px 0; font-size: 13pt; color: #1a1a1a; border-bottom: 1px solid #e8dcc4; text-align: right; vertical-align: top; width: 25%;">
                {{ line.total|formatCurrency(currency) }}
            </td>
        </tr>
    {% endfor %}
</table>

<div class="editorial-marker" style="margin-bottom: 12px; text-align: right;">IV. {{ 'invoice.total'|trans }}</div>
{{ inv.totals_block(invoice, currency, {totalBg: '#f5ebd9', totalColor: '#1a1a1a', balanceBg: '#f5ebd9', balanceColor: '#94704a', mono: 'Georgia, serif'}) }}
{{ inv.terms_block(invoice, {labelColor: '#94704a', borderColor: '#e8dcc4'}) }}
{{ inv.payment_cta(invoice, '#94704a') }}
{% endblock %}
