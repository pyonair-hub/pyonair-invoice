{# Freelancer Friendly preview #}
{% set currency = invoice.client.currency %}
{% set hasOutstandingBalance = invoice_has_outstanding_balance(invoice) %}
{% set primary = invoice_primary_contact(invoice) %}
{% set greeting = primary is not null and primary.firstName is not empty ? primary.firstName : invoice.client.name %}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&display=swap">

<div class="invoice-template invoice-template-friendly" style="background: #fffaf3;">
    <div class="card border-0 shadow-sm" style="background: #fffaf3;">
        <div class="card-body p-5">
            <div class="d-flex justify-content-between mb-4">
                <div>
                    {% if app_logo() is not empty %}{{ app_logo(40) }}{% endif %}
                    <div class="fs-5 fw-bold mt-2">{{ company_name() }}</div>
                </div>
                <div class="text-end">
                    <div class="text-uppercase small" style="color: #94704a; letter-spacing: 2px;">{{ 'invoice.pdf.title'|trans }}</div>
                    <div class="fs-3 fw-bold">#{{ invoice.invoiceId }}</div>
                </div>
            </div>

            <div style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 28px; line-height: 1.2;" class="mb-2">
                {{ 'invoice.template.friendly.greeting'|trans({'%name%': greeting}) }}
            </div>
            <p class="text-muted mb-4">{{ 'invoice.template.friendly.intro'|trans }}</p>

            <div class="mb-4">
                <div class="text-uppercase small mb-1" style="color: #94704a; letter-spacing: 1px;">{{ 'invoice.to'|trans }}</div>
                <strong>{{ invoice.client }}</strong>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 mb-2">
                    <div class="p-3 rounded" style="background: #fff1e0;">
                        <div class="text-uppercase small mb-1" style="color: #94704a; letter-spacing: 1px;">{{ 'invoice.date'|trans }}</div>
                        <strong>{{ invoice.invoiceDate|date('F j, Y') }}</strong>
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="p-3 rounded" style="background: #fff1e0;">
                        <div class="text-uppercase small mb-1" style="color: #94704a; letter-spacing: 1px;">{{ 'invoice.due_date'|trans }}</div>
                        <strong>{% if invoice.due %}{{ invoice.due|date('F j, Y') }}{% else %}—{% endif %}</strong>
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="p-3 rounded" style="background: #ecf7ee;">
                        <div class="text-uppercase small mb-1" style="color: #2e963a; letter-spacing: 1px;">{% if hasOutstandingBalance %}{{ 'invoice.balance_due'|trans }}{% else %}{{ 'invoice.total_due'|trans }}{% endif %}</div>
                        <strong style="color: #166534;" class="fs-5">{{ (hasOutstandingBalance ? invoice.balance : invoice.total)|formatCurrency(currency) }}</strong>
                    </div>
                </div>
            </div>

            <table class="table">
                <thead>
                    <tr style="border-bottom: 1px solid #e8d7b8;">
                        <th class="text-uppercase small" style="color: #94704a;">{{ 'invoice.item.heading.description'|trans }}</th>
                        <th class="text-uppercase small text-end" style="color: #94704a;">{{ 'invoice.item.heading.qty'|trans }}</th>
                        <th class="text-uppercase small text-end" style="color: #94704a;">{{ 'invoice.item.heading.total'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for line in invoice.lines %}
                        <tr style="border-bottom: 1px solid #f1eada;">
                            <td>{{ line.description|nl2br }}</td>
                            <td class="text-end text-muted">{{ line.qty }}</td>
                            <td class="text-end fw-bold">{{ line.total|formatCurrency(currency) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="row justify-content-end mt-4">
                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-2"><span>{{ 'invoice.subtotal'|trans }}</span><span>{{ invoice.baseTotal|formatCurrency(currency) }}</span></div>
                    {% if invoice.tax.positive %}<div class="d-flex justify-content-between mb-2 text-muted"><span>{{ 'invoice.tax'|trans }}</span><span>{{ invoice.tax|formatCurrency(currency) }}</span></div>{% endif %}
                    {% if invoice.discount.type is not empty %}<div class="d-flex justify-content-between mb-2 text-muted"><span>{{ 'invoice.discount'|trans }}</span><span class="text-danger">-{{ discount(invoice)|formatCurrency(currency) }}</span></div>{% endif %}
                    <div class="d-flex justify-content-between p-3 rounded" style="background: #ecf7ee;">
                        <strong>{{ hasOutstandingBalance ? 'invoice.balance'|trans : 'invoice.total'|trans }}</strong>
                        <strong style="color: #166534;" class="fs-4">{{ (hasOutstandingBalance ? invoice.balance : invoice.total)|formatCurrency(currency) }}</strong>
                    </div>
                </div>
            </div>

            <div class="mt-4" style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: #475569;">
                {{ 'invoice.template.friendly.signoff'|trans }}
            </div>
        </div>
    </div>
</div>
