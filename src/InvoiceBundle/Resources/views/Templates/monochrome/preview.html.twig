{# Monochrome Luxury preview #}
{% set currency = invoice.client.currency %}
{% set hasOutstandingBalance = invoice_has_outstanding_balance(invoice) %}

<div class="invoice-template invoice-template-monochrome" style="background: #0b0b0b; padding: 32px; border-radius: 8px;">
    <div class="card border-0" style="background: #f5f1e8;">
        <div class="card-body p-5">
            <div class="d-flex justify-content-between text-uppercase mb-4" style="font-size: 11px; letter-spacing: 4px;">
                <div>{{ 'invoice.pdf.title'|trans }}</div>
                <div>{{ company_name() }}</div>
            </div>
            <div style="font-family: Georgia, serif; font-size: 64px; line-height: 1.05; letter-spacing: -1px; color: #1a1a1a; margin-bottom: 24px;">
                {{ 'invoice.number_prefix'|trans }} {{ invoice.invoiceId }}
            </div>
            <div class="row pt-3 border-top border-dark">
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase mb-1" style="letter-spacing: 2px;">{{ 'invoice.to'|trans }}</div>
                    <div class="fw-bold">{{ invoice.client }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase mb-1" style="letter-spacing: 2px;">{{ 'invoice.date'|trans }}</div>
                    <div>{{ invoice.invoiceDate|date('F j, Y') }}</div>
                </div>
                <div class="col-md-4 text-end">
                    <div class="text-muted small text-uppercase mb-1" style="letter-spacing: 2px;">{% if hasOutstandingBalance %}{{ 'invoice.balance_due'|trans }}{% else %}{{ 'invoice.total_due'|trans }}{% endif %}</div>
                    <div style="font-family: Georgia, serif; font-size: 28px; color: #d4a94a; font-weight: bold;">
                        {{ (hasOutstandingBalance ? invoice.balance : invoice.total)|formatCurrency(currency) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 mt-2" style="background: #ffffff;">
        <div class="card-body p-5">
            <table class="table">
                <thead>
                    <tr style="border-bottom: 1px solid #e0d8c8;">
                        <th scope="col" class="text-uppercase small text-muted">{{ 'invoice.item.heading.description'|trans }}</th>
                        <th scope="col" class="text-uppercase small text-muted text-end">{{ 'invoice.item.heading.qty'|trans }} × {{ 'invoice.item.heading.price'|trans }}</th>
                        <th scope="col" class="text-uppercase small text-muted text-end">{{ 'invoice.item.heading.total'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for line in invoice.lines %}
                        <tr style="border-bottom: 1px solid #e0d8c8;">
                            <td>{{ line.description|nl2br }}</td>
                            <td class="text-muted text-end">{{ line.qty }} × {{ line.price|formatCurrency(currency) }}</td>
                            <td class="text-end fw-bold">{{ line.total|formatCurrency(currency) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div class="row justify-content-end mt-4">
                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-2"><span>{{ 'invoice.subtotal'|trans }}</span><span>{{ invoice.baseTotal|formatCurrency(currency) }}</span></div>
                    {% if invoice.tax.positive %}<div class="d-flex justify-content-between mb-2 text-muted"><span>{{ 'invoice.tax'|trans }}</span><span>{{ invoice.tax|formatCurrency(currency) }}</span></div>{% endif %}
                    {% if invoice.discount.type is not empty %}<div class="d-flex justify-content-between mb-2 text-muted"><span>{{ 'invoice.discount'|trans }}</span><span class="text-danger">-{{ discount(invoice)|formatCurrency(currency) }}</span></div>{% endif %}
                    <div class="d-flex justify-content-between p-3" style="background: #1a1a1a;">
                        <strong style="color: #f5f1e8;">{{ hasOutstandingBalance ? 'invoice.balance'|trans : 'invoice.total'|trans }}</strong>
                        <strong style="font-family: Georgia, serif; color: #d4a94a;">{{ (hasOutstandingBalance ? invoice.balance : invoice.total)|formatCurrency(currency) }}</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
