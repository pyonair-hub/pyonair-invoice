{# Photographer preview #}
{% set currency = invoice.client.currency %}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&display=swap">

<div class="invoice-template invoice-template-photographer" style="background: #faf3e6; font-family: 'Cormorant Garamond', Georgia, serif; color: #2a2418;">
    <div class="d-flex">
        <div style="background: linear-gradient(180deg, #b85a35 0%, #a2492b 50%, #7d3a22 100%); width: 56px;">
            <div class="text-uppercase text-center py-4" style="color: #faf3e6; letter-spacing: 4px; writing-mode: vertical-rl; font-size: 13px;">
                {{ 'invoice.pdf.title'|trans }}
            </div>
        </div>
        <div class="flex-grow-1 p-5">
            <div style="font-size: 42px; line-height: 1;">{{ company_name() }}</div>
            <div class="text-uppercase mb-4" style="color: #7a6a4a; letter-spacing: 2px; font-size: 12px;">{{ 'invoice.template.photographer.subtitle'|trans }}</div>

            <div class="d-flex justify-content-between mb-4">
                <div style="font-size: 28px; color: #a2492b;">{{ 'invoice.number_prefix'|trans }} {{ invoice.invoiceId }}</div>
                <div class="text-end">
                    <div class="text-muted small text-uppercase">{{ 'invoice.date'|trans }}</div>
                    <div>{{ invoice.invoiceDate|date('F j, Y') }}</div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="text-uppercase small mb-1" style="color: #a2492b; letter-spacing: 2px;">{{ 'invoice.template.photographer.client_label'|trans }}</div>
                    <div class="fw-semibold fs-5">{{ invoice.client }}</div>
                </div>
                <div class="col-md-6">
                    <div class="text-uppercase small mb-1" style="color: #a2492b; letter-spacing: 2px;">{{ 'invoice.template.photographer.studio_label'|trans }}</div>
                    <div class="fw-semibold fs-5">{{ company_name() }}</div>
                </div>
            </div>

            <table class="table" style="background: transparent;">
                <tbody>
                    {% for line in invoice.lines %}
                        <tr style="border-bottom: 1px solid #e8d7b8;">
                            <td>
                                <div class="fs-5">{{ line.description|nl2br }}</div>
                                <div class="text-muted small">{{ line.qty }} × {{ line.price|formatCurrency(currency) }}</div>
                            </td>
                            <td class="text-end fs-4 fw-bold" style="color: #a2492b;">{{ line.total|formatCurrency(currency) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="row justify-content-end mt-4">
                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-2"><span>{{ 'invoice.subtotal'|trans }}</span><span>{{ invoice.baseTotal|formatCurrency(currency) }}</span></div>
                    {% if invoice.tax.positive %}<div class="d-flex justify-content-between mb-2"><span>{{ 'invoice.tax'|trans }}</span><span>{{ invoice.tax|formatCurrency(currency) }}</span></div>{% endif %}
                    <div class="d-flex justify-content-between p-3 rounded" style="background: #a2492b; color: #faf3e6;">
                        <strong>{{ 'invoice.total'|trans }}</strong>
                        <strong>{{ invoice.total|formatCurrency(currency) }}</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
