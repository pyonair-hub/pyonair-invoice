{% extends '@SolidInvoiceCore/Layout/login.html.twig' %}

{% block page_title %}{{ app_name }} - {{ 'mcp.error.title'|trans({}, 'SolidInvoiceMcpBundle') }}{% endblock %}

{% block content %}
    <div class="page page-center">
        <div class="container container-tight py-4">
            <div class="card card-md">
                <div class="card-body text-center">
                    {{ ux_icon('tabler:alert-circle', {width: 48, height: 48, class: 'text-danger'}) }}

                    <h2 class="mt-3">{{ 'mcp.error.title'|trans({}, 'SolidInvoiceMcpBundle') }}</h2>

                    <p class="text-muted">
                        <strong>{{ error }}</strong>
                    </p>

                    <p class="text-muted">
                        {{ error_description }}
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
