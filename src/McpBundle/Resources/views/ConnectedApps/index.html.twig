{% extends '@SolidInvoiceUser/Layout/profile.html.twig' %}

{% set menuItem = 'connected-apps' %}

{% block title %}{{ 'mcp.connected_apps.title'|trans({}, 'SolidInvoiceMcpBundle') }}{% endblock %}

{% block profile_content %}
    <div class="page-header">
        <h2 class="page-title">
            {{ ux_icon('tabler:plug-connected', {width: 24, height: 24, class: 'me-2'}) }}
            {{ 'mcp.connected_apps.title'|trans({}, 'SolidInvoiceMcpBundle') }}
        </h2>
    </div>

    {% if connected_apps is empty %}
        <div class="empty">
            <p class="empty-title">{{ 'mcp.connected_apps.empty'|trans({}, 'SolidInvoiceMcpBundle') }}</p>
        </div>
    {% else %}
        <div class="row row-cards">
            {% for app in connected_apps %}
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-start">
                                <div class="flex-grow-1">
                                    <h3 class="card-title">{{ app.client.name }}</h3>

                                    <div class="mb-2 text-muted small">
                                        {{ 'mcp.connected_apps.scopes'|trans({}, 'SolidInvoiceMcpBundle') }}:
                                        {% for scope in app.scopes %}
                                            <span class="badge bg-blue-lt">{{ scope }}</span>
                                        {% endfor %}
                                    </div>

                                    <div class="mb-2 text-muted small">
                                        {{ app.company.name }}
                                    </div>

                                    <div class="text-muted small">
                                        {% if app.last_used %}
                                            {{ 'mcp.connected_apps.last_used'|trans({}, 'SolidInvoiceMcpBundle') }}:
                                            {{ app.last_used|date('Y-m-d H:i') }}
                                        {% else %}
                                            {{ 'mcp.connected_apps.never_used'|trans({}, 'SolidInvoiceMcpBundle') }}
                                        {% endif %}
                                    </div>
                                </div>

                                <form method="post" action="{{ path('mcp_connected_apps_revoke', {'id': app.client.id}) }}">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('mcp_connected_apps_revoke') }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        {{ ux_icon('tabler:x', {width: 16, height: 16, class: 'me-1'}) }}
                                        {{ 'mcp.connected_apps.revoke'|trans({}, 'SolidInvoiceMcpBundle') }}
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
