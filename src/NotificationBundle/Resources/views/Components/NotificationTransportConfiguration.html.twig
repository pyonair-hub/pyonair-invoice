<div {{ attributes }}>
    <twig:Ui:Card>
        <twig:block name="header">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h3 class="card-title mb-1 d-flex align-items-center gap-2">
                        {{ ux_icon('tabler:bell-ringing', {width: 20, height: 20, class: 'text-primary'}) }}
                        {% if not isNewSetting %}
                            {{ transportSetting.name }}
                        {% else %}
                            {{ 'Add %type% Integration'|trans({'%type%': notificationType}) }}
                        {% endif %}
                    </h3>
                    <p class="text-muted small mb-0">
                        {{ 'Configure notification integration credentials'|trans }}
                    </p>
                </div>
                <a href="{{ path('_notification_integration') }}"
                   class="btn btn-ghost btn-icon"
                   aria-label="{{ 'Close'|trans }}">
                    {{ ux_icon('tabler:x', {width: 20, height: 20}) }}
                </a>
            </div>
        </twig:block>

        {{ form_start(form, {
            attr: {
                'data-action': 'live#action:prevent',
                'data-live-action-param': 'save'
            }
        }) }}
            <div class="mb-4">
                {{ form_widget(form) }}
            </div>
        {{ form_end(form) }}

        <twig:block name="footer">
            <div class="d-flex justify-content-between align-items-center gap-3">
                {% if not isNewSetting %}
                    <button type="button"
                            class="btn btn-outline-danger"
                            data-action="live#action"
                            data-live-action-param="showDeleteConfirmation"
                            aria-label="{{ 'Delete integration'|trans }}">
                        {{ ux_icon('tabler:trash', {width: 18, height: 18}) }}
                        {{ 'Delete'|trans }}
                    </button>
                {% else %}
                    <a href="{{ path('_notification_integration') }}"
                       class="btn btn-ghost">
                        {{ ux_icon('tabler:x', {width: 18, height: 18}) }}
                        {{ 'Cancel'|trans }}
                    </a>
                {% endif %}
                <button type="submit"
                        class="btn btn-primary btn-save"
                        data-action="live#action"
                        data-live-action-param="save"
                        data-loading="addAttribute(disabled)"
                        aria-label="{{ 'Save integration'|trans }}">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'Save Integration'|trans }}
                </button>
            </div>
        </twig:block>
    </twig:Ui:Card>

    {# Delete Confirmation Nested Modal #}
    {% if showDeleteConfirmation %}
        <div class="delete-confirmation-backdrop"
             role="presentation"
             aria-hidden="true"
             data-action="click->live#action"
             data-live-action-param="cancelDelete">
        </div>
        <div class="delete-confirmation-modal"
             role="dialog"
             aria-modal="true"
             aria-labelledby="delete-modal-title">
            <div class="delete-confirmation-container">
                <div class="delete-confirmation-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="delete-icon-wrapper">
                            {{ ux_icon('tabler:alert-triangle', {width: 24, height: 24, class: 'text-danger'}) }}
                        </div>
                        <div>
                            <h4 id="delete-modal-title" class="mb-1">{{ 'Delete Integration'|trans }}</h4>
                            <p class="text-muted small mb-0">{{ 'This action cannot be undone'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="delete-confirmation-body">
                    <p class="mb-0">
                        {{ 'Are you sure you want to delete'|trans }} <strong>{{ transportSetting.name }}</strong>?
                        {{ 'This will remove the notification integration and cannot be reversed.'|trans }}
                    </p>
                </div>
                <div class="delete-confirmation-footer">
                    <button type="button"
                            class="btn btn-ghost"
                            data-action="live#action"
                            data-live-action-param="cancelDelete">
                        {{ 'Cancel'|trans }}
                    </button>
                    <button type="button"
                            class="btn btn-danger"
                            data-action="live#action"
                            data-live-action-param="confirmDelete"
                            data-loading="addAttribute(disabled)">
                        {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                        {{ 'Delete Integration'|trans }}
                    </button>
                </div>
            </div>
        </div>
    {% endif %}
</div>
