<div class="payment-marketplace" {{ attributes }}>
    {% include "@SolidInvoiceCore/flash.html.twig" %}

    {# Mobile Tabs #}
    <ul class="nav nav-tabs d-md-none mb-4" role="tablist">
        <li class="nav-item">
            <a href="{{ path('_payment_settings_index', {view: 'marketplace'}) }}"
               class="nav-link{{ view == 'marketplace' ? ' active' : '' }}"
               {% if view == 'marketplace' %}aria-current="page"{% endif %}>
                <span class="nav-link-icon">
                    {{ ux_icon('tabler:apps', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Marketplace'|trans }}</span>
            </a>
        </li>
        <li class="nav-item">
            <a href="{{ path('_payment_settings_index', {view: 'active'}) }}"
               class="nav-link{{ view == 'active' ? ' active' : '' }}"
               {% if view == 'active' %}aria-current="page"{% endif %}>
                <span class="nav-link-icon">
                    {{ ux_icon('tabler:list-check', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Active'|trans }} <span class="badge bg-secondary-lt ms-1">{{ activeMethods|length }}</span></span>
            </a>
        </li>
    </ul>

    {# Desktop Split View #}
    <div class="row g-4">
        {# Left Panel: Gateway Marketplace #}
        <div class="col-md-5 col-lg-4 {{ view == 'active' ? 'd-none d-md-block' : '' }}">
            <div class="marketplace-panel">
                <div class="marketplace-header mb-4">
                    <h5 class="mb-2 d-flex align-items-center gap-2">
                        {{ ux_icon('tabler:apps', {width: 20, height: 20, class: 'text-primary'}) }}
                        {{ 'Payment Gateways'|trans }}
                    </h5>
                    <p class="text-muted small mb-3">
                        {{ 'Choose from popular payment processors or add custom gateways'|trans }}
                    </p>

                    {# Search Input #}
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            {{ ux_icon('tabler:search', {width: 18, height: 18}) }}
                        </span>
                        <input type="text"
                               class="form-control"
                               placeholder="{{ 'Search gateways...'|trans }}"
                               data-model="searchQuery"
                               aria-label="{{ 'Search payment gateways'|trans }}">
                        {% if searchQuery %}
                            <button type="button"
                                    class="btn btn-ghost btn-icon position-absolute end-0 top-50 translate-middle-y marketplace-search-clear"
                                    data-action="live#action"
                                    data-live-action-param="clearSearch"
                                    aria-label="{{ 'Clear search'|trans }}">
                                {{ ux_icon('tabler:x', {width: 16, height: 16}) }}
                            </button>
                        {% endif %}
                    </div>
                </div>

                {# Gateway Cards Grid #}
                <div class="gateway-grid">
                    {% if filteredGateways|length > 0 %}
                        {% for gateway in filteredGateways %}
                            <div class="gateway-card {{ gateway.isConfigured ? 'is-configured' : '' }} {{ gateway.name == 'custom' ? 'is-custom-gateway' : '' }}"
                                 data-gateway="{{ gateway.name }}">
                                <div class="gateway-card-body">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="gateway-icon">
                                            {{ ux_icon(gateway.icon, {width: 24, height: 24}) }}
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                                <h6 class="mb-0">{{ gateway.displayName }}</h6>
                                                {% if gateway.isPopular %}
                                                    <span class="badge bg-primary-lt badge-sm">
                                                        {{ 'Popular'|trans }}
                                                    </span>
                                                {% endif %}
                                                {% if gateway.isConfigured %}
                                                    <span class="badge bg-success-lt badge-sm">
                                                        {{ ux_icon('tabler:check', {width: 12, height: 12}) }}
                                                        <span class="visually-hidden">{{ 'Configured'|trans }}</span>
                                                    </span>
                                                {% endif %}
                                            </div>
                                            <p class="text-muted small mb-2">{{ gateway.description }}</p>
                                            <a href="{{ path('_payment_settings_index', {selectedGateway: gateway.name}) }}"
                                               class="btn btn-sm btn-outline-primary">
                                                {% if gateway.isConfigured %}
                                                    {{ ux_icon('tabler:edit', {width: 14, height: 14}) }}
                                                    {{ 'Edit'|trans }}
                                                {% else %}
                                                    {{ ux_icon('tabler:plus', {width: 14, height: 14}) }}
                                                    {{ 'Configure'|trans }}
                                                {% endif %}
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty">
                            <div class="empty-icon">
                                {{ ux_icon('tabler:search-off', {width: 48, height: 48}) }}
                            </div>
                            <p class="empty-title">{{ 'No gateways found matching your search'|trans }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Right Panel: Active Methods List (Always Visible) #}
        <div class="col-md-7 col-lg-8 {{ view == 'marketplace' ? 'd-none d-md-block' : '' }}">
            {# Active Methods List #}
            <div class="active-methods-panel">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h5 class="mb-0 d-flex align-items-center gap-2">
                            {{ ux_icon('tabler:list-check', {width: 20, height: 20, class: 'text-primary'}) }}
                            {{ 'Active Payment Methods'|trans }}
                        </h5>
                        <span class="badge bg-secondary-lt">{{ activeMethods|length }}</span>
                    </div>

                    {% if activeMethods|length > 0 %}
                        <div class="active-methods-list">
                            {% for method in activeMethods %}
                                <div class="card active-method-card">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start justify-content-between gap-3">
                                            <div class="d-flex align-items-start gap-3 flex-grow-1 min-w-0">
                                                <div class="payment-method-icon">
                                                    {{ ux_icon(this.getGatewayIcon(method.factoryName), {width: 24, height: 24}) }}
                                                </div>
                                                <div class="flex-grow-1 min-w-0">
                                                    <h6 class="mb-2">{{ method.name }}</h6>
                                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                                        <span class="badge {{ method.enabled ? 'bg-success-lt' : 'bg-secondary-lt' }}">
                                                            {{ method.enabled ? 'Enabled'|trans : 'Disabled'|trans }}
                                                        </span>
                                                        {% if method.config.sandbox|default(false) %}
                                                            <span class="badge bg-warning-lt">
                                                                {{ ux_icon('tabler:flask', {width: 12, height: 12}) }}
                                                                {{ 'Test Mode'|trans }}
                                                            </span>
                                                        {% endif %}
                                                        {% if method.isInternal %}
                                                            <span class="badge bg-info-lt">
                                                                {{ 'Offline'|trans }}
                                                            </span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 flex-shrink-0">
                                                <a href="{{ path('_payment_settings_index', {selectedGateway: method.gatewayName}) }}"
                                                   class="btn btn-outline-secondary btn-sm"
                                                   aria-label="{{ 'Edit %name%'|trans({'%name%': method.name}) }}">
                                                    {{ ux_icon('tabler:edit', {width: 16, height: 16}) }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty">
                            <div class="empty-icon">
                                {{ ux_icon('tabler:credit-card-off', {width: 64, height: 64}) }}
                            </div>
                            <p class="empty-title">{{ 'No payment methods configured'|trans }}</p>
                            <p class="empty-subtitle text-secondary">
                                {{ 'Get started by selecting a gateway from the marketplace on the left.'|trans }}
                            </p>
                            <div class="empty-action">
                                <a href="{{ path('_payment_settings_index', {view: 'marketplace'}) }}"
                                   class="btn btn-primary">
                                    {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
                                    {{ 'Browse Payment Gateways'|trans }}
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
        </div>
    </div>

    {# Configuration Modal #}
    {% if selectedGateway is not empty %}
        <div class="payment-modal-backdrop"
             role="presentation"
             data-action="click->live#action"
             data-live-action-param="closeModal">
        </div>
        <div class="payment-modal"
             role="dialog"
             aria-modal="true"
             aria-labelledby="payment-modal-title"
             data-controller="payment-modal">
            <div class="payment-modal-container">
                <div class="payment-modal-header">
                    <h3 id="payment-modal-title" class="payment-modal-title">
                        {{ 'Configure Payment Gateway'|trans }}
                    </h3>
                    <a href="{{ path('_payment_settings_index') }}"
                       class="btn btn-ghost btn-icon payment-modal-close"
                       aria-label="{{ 'Close'|trans }}"
                       title="{{ 'Close (Esc)'|trans }}">
                        {{ ux_icon('tabler:x', {width: 20, height: 20}) }}
                    </a>
                </div>
                <div class="payment-modal-body">
                    <twig:PaymentSettings method="{{ selectedGateway }}" />
                </div>
            </div>
        </div>
    {% endif %}
</div>
