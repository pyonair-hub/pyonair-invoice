{% extends "@SolidInvoiceCore/Layout/Email/notification.html.twig" %}
{% import "@SolidInvoiceCore/Layout/Email/components.html.twig" as email %}

{%- block title -%}
    {{ 'quote.status_change.heading'|trans({}, 'email') }}
{%- endblock -%}

{%- block content -%}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #1e293b; font-size: 16px; line-height: 1.5; margin: 0 0 24px 0; Margin: 0 0 24px 0;">
                    {{ 'quote.status_change.message'|trans({}, 'email') }}
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('sm') }}

    {# Quote details #}
    {{ email.info_row('quote.status_change.id'|trans({}, 'email'), quote.quoteId) }}

    {% if quote.client %}
        {{ email.spacer('xs') }}
        {{ email.info_row('quote.status_change.client'|trans({}, 'email'), quote.client.name) }}
    {% endif %}

    {{ email.spacer('sm') }}

    {# Status display #}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="font-weight: 600; color: #1e293b; margin: 0 0 8px 0; Margin: 0 0 8px 0;">
                    {{ 'quote.status_change.new_status'|trans({}, 'email') }}
                </p>
                <div style="margin: 8px 0; Margin: 8px 0;">
                    {{ quote_label(quote.status) }}
                </div>
            </columns>
        </row>
    {% endapply %}

    {{ email.divider('md') }}

    {# View button #}
    {{ email.button('quote.status_change.view_quote'|trans({}, 'email'), url('_quotes_view', {'id': quote.id}), 'primary', 'large') }}

    {{ email.spacer('md') }}
{%- endblock -%}
