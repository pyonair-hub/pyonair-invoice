{% extends '@SolidInvoiceSaas/Email/Onboarding/_layout.html.twig' %}

{% block title %}{{ 'onboarding.upgrade_offer.subject'|trans({}, 'email') }}{% endblock %}

{% block content %}
    <span class="onb-eyebrow danger">{{ 'onboarding.upgrade_offer.eyebrow'|trans({}, 'email') }}</span>
    <h1 class="onb-h1">{{ 'onboarding.upgrade_offer.heading'|trans({}, 'email') }}</h1>
    <p class="onb-p lede">{{ 'onboarding.upgrade_offer.lede'|trans({}, 'email') }}</p>

    {# Pricing card #}
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="onb-pricing" style="margin: 24px 0 8px 0; Margin: 24px 0 8px 0;">
        <tr>
            <td style="padding: 0;">
                <div class="onb-plan-name">{{ plan.name|default('SolidInvoice') }}</div>
                <div>
                    <span class="onb-price">${{ (plan.price / 100)|number_format(2) }}</span>
                    <span class="onb-price-per">{{ 'onboarding.upgrade_offer.per'|trans({}, 'email') }}</span>
                </div>
                <ul class="onb-pricing-list">
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.1'|trans({}, 'email') }}</li>
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.2'|trans({}, 'email') }}</li>
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.3'|trans({}, 'email') }}</li>
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.4'|trans({}, 'email') }}</li>
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.5'|trans({}, 'email') }}</li>
                    <li><span class="onb-check-dot">&#10003;</span>{{ 'onboarding.upgrade_offer.feature.6'|trans({}, 'email') }}</li>
                </ul>
            </td>
        </tr>
    </table>

    {% if coupon_code %}
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="onb-callout" style="margin: 24px 0;">
            <tr>
                <td style="vertical-align: middle; line-height: 1.6;">
                    <div class="onb-callout-title">{{ 'onboarding.upgrade_offer.coupon_heading'|trans({}, 'email') }}</div>
                    <div style="font-family: monospace; font-size: 22px; font-weight: 700; letter-spacing: 0.1em; color: #1e293b; margin: 8px 0; Margin: 8px 0;">{{ coupon_code }}</div>
                    <div class="onb-callout-sub">{{ 'onboarding.upgrade_offer.coupon_desc'|trans({}, 'email') }}</div>
                </td>
            </tr>
        </table>
    {% endif %}

    <div class="onb-cta-wrapper">
        <a href="{{ url('saas_subscription_checkout') }}" class="onb-cta" rel="external" target="_blank">
            {{ 'onboarding.upgrade_offer.cta'|trans({}, 'email') }} &rarr;
        </a>
    </div>

    <p class="onb-fine-print">{{ 'onboarding.upgrade_offer.fine_print'|trans({}, 'email') }}</p>
{% endblock %}

{% block ps %}{{ 'onboarding.upgrade_offer.ps'|trans({}, 'email') }}{% endblock %}
