 # Subscription alert banner component
 # Displays subscription warnings/notifications at the top of pages
 #
 # @param string type - alert type (warning, danger, info)
 # @param string icon - Tabler icon name (e.g., 'tabler:clock-hour-4')
 # @param string title - bold title text
 # @param string message - main message text
 # @param string|null cta_label - optional button text (omit for no CTA)
 # @param string|null cta_url - optional button URL (omit for no CTA)
 #}

<div class="alert alert-{{ type }} alert-banner mb-0" role="alert">
    <div class="d-flex align-items-center gap-3">
        <div class="alert-icon">
            {{ ux_icon(icon, {width: 24, height: 24}) }}
        </div>
        <div class="flex-grow-1">
            <strong>{{ title }}</strong> - {{ message }}
        </div>
        {% if cta_label is defined and cta_url is defined and cta_label and cta_url %}
            <a href="{{ cta_url }}" class="btn btn-{{ type }} btn-sm">
                {{ cta_label }}
            </a>
        {% endif %}
    </div>
</div>
