{% extends '@SolidInvoiceCore/Layout/default_no_nav.html.twig' %}

{% block heading %}
    {% include '@SolidInvoiceSaas/subscription/_header.html.twig' %}
{% endblock heading %}

{% block content %}
    {% set availableCompanies = app.user.companies|filter(v => v.id != company_id()) %}

    <div class="subscription-page subscription-cancelled-page">
        <div class="subscription-container">
            {# Hero Icon #}
            <div class="subscription-icon subscription-icon-danger">
                {{ ux_icon('tabler:heart-broken', {width: 32, height: 32}) }}
            </div>

            {# Headline #}
            <h1 class="subscription-title">{{ 'We\'re sorry to see you go'|trans }}</h1>
            <p class="subscription-subtitle">
                {% trans with {'%price%': subscription.plan.price|formatCurrency('USD')} %}
                    Your subscription has been cancelled. We'd love to have you back at %price%/month whenever you're ready.
                {% endtrans %}
            </p>

            {# Features Requiring Reactivation #}
            <div class="subscription-benefits">
                <h3>{{ 'Features requiring reactivation:'|trans }}</h3>
                <ul>
                    <li>
                        {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                        {{ 'Create new invoices and quotes'|trans }}
                    </li>
                    <li>
                        {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                        {{ 'Accept online payments from clients'|trans }}
                    </li>
                    <li>
                        {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                        {{ 'Access to payment history and reports'|trans }}
                    </li>
                    <li>
                        {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                        {{ 'Client and contact management'|trans }}
                    </li>
                    <li>
                        {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                        {{ 'Recurring invoices and subscriptions'|trans }}
                    </li>
                </ul>
            </div>

            {# Primary CTA #}
            <div class="subscription-actions">
                <a href="{{ path('saas_subscription_plans') }}" class="btn btn-primary btn-lg">
                    {{ ux_icon('tabler:arrow-back-up', {width: 20, height: 20}) }} {{ 'Reactivate Subscription'|trans }}
                </a>
                <a href="https://solidinvoice.co/contact" class="btn btn-ghost" target="_blank" rel="external noreferrer noopener">
                    {{ ux_icon('tabler:help', {width: 18, height: 18}) }} {{ 'Contact Support'|trans }}
                </a>
            </div>

            {# Reassuring Message #}
            <twig:Ui:Alert type="info" class="mt-4 text-start">
                <div class="d-flex align-items-start gap-2">
                    {{ ux_icon('tabler:info-circle', {width: 20, height: 20}) }}
                    <div>
                        <strong>{{ 'Changed your mind?'|trans }}</strong>
                        {{ 'We\'d love to have you back! Your data is safe and will be waiting for you when you reactivate.'|trans }}
                    </div>
                </div>
            </twig:Ui:Alert>

            {# Info Alert for Multiple Companies #}
            {% if availableCompanies|length > 0 %}
                <twig:Ui:Alert type="info" class="mt-3 text-start">
                    <div class="d-flex align-items-center gap-2">
                        {{ ux_icon('tabler:building', {width: 20, height: 20}) }}
                        <div>
                            {{ 'You have access to other companies.'|trans }}
                            <a href="{{ path('_switch_company', {'id': availableCompanies|first.id}) }}" class="alert-link">
                                {{ 'Switch to %company%'|trans({'%company%': availableCompanies|first}) }}
                            </a>
                        </div>
                    </div>
                </twig:Ui:Alert>
            {% endif %}
        </div>
    </div>
{% endblock content %}
