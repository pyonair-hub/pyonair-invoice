{% form_theme form '@SolidInvoiceSettings/Form/fields.html.twig' %}

{# Tab metadata for navigation #}
{% set tabMeta = {
    'system': {'title': 'Company'|trans, 'icon': 'tabler:building'},
    'invoice': {'title': 'Invoices'|trans, 'icon': 'tabler:file-invoice'},
    'quote': {'title': 'Quotes'|trans, 'icon': 'tabler:file-text'},
    'email': {'title': 'Email'|trans, 'icon': 'tabler:mail'}
} %}

<div class="settings-page"{{ attributes }}>
    {# Tabs Navigation #}
    <ul class="nav nav-underline mb-4" role="tablist">
        {% for settingsSection, setting in appSettings %}
            {% set meta = tabMeta[settingsSection]|default({
                'title': settingsSection|replace({'_': ' '})|title|trans,
                'icon': 'tabler:settings'
            }) %}
            <li class="nav-item">
                <a href="{{ path('_settings', {section: settingsSection}) }}"
                   class="nav-link{{ settingsSection is same as section ? ' active' : '' }}"
                   {% if settingsSection is same as section %}aria-current="page"{% endif %}>
                    <span class="nav-link-icon d-none d-sm-inline-block">
                        {{ ux_icon(meta.icon, {width: 16, height: 16}) }}
                    </span>
                    <span>{{ meta.title }}</span>
                </a>
            </li>
        {% endfor %}
    </ul>

    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'prevent|files|save'
        }
    }) }}

    {# Settings Content Card #}
    <div class="card settings-content-card">
        <div class="card-body">
            {# Render form fields with better organization #}
            {% if section == 'system' %}
                {# Company Settings - Custom Layout #}
                {% if form.company is defined %}
                    {# Company Profile Section - Name first, then Logo #}
                    <div class="mb-4 pb-4 border-bottom">
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:building', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'Company Profile'|trans }}
                        </h3>
                        <div class="row g-4">
                            {% if form.company.company_name is defined %}
                                <div class="col-12">
                                    {{ form_row(form.company.company_name, {
                                        label: 'Company Name'|trans,
                                        attr: {placeholder: 'Your company name'|trans}
                                    }) }}
                                </div>
                            {% endif %}
                            {% if form.company.logo is defined %}
                                <div class="col-12">
                                    <label class="form-label">{{ 'Company Logo'|trans }}</label>
                                    {{ form_row(form.company.logo) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {# Business Details Section #}
                    <div class="mb-4 pb-4 border-bottom">
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:file-text', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'Business Details'|trans }}
                        </h3>
                        <div class="row g-3">
                            {% if form.company.currency is defined %}
                                <div class="col-md-6">
                                    {{ form_row(form.company.currency, {
                                        label: 'Default Currency'|trans,
                                        help: 'The default currency used for new invoices and quotes.'|trans
                                    }) }}
                                </div>
                            {% endif %}
                            {% if form.company.vat_number is defined %}
                                <div class="col-md-6">
                                    {{ form_row(form.company.vat_number, {
                                        label: 'VAT / Tax Number'|trans,
                                        help: 'Your company VAT or tax identification number. Click Validate to verify EU VAT numbers.'|trans
                                    }) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {# Contact Details Section #}
                    {% if form.company.contact_details is defined %}
                        <div class="mb-4 pb-4 border-bottom">
                            <h3 class="d-flex align-items-center gap-2 mb-3">
                                {{ ux_icon('tabler:map-pin', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                                {{ 'Contact Details'|trans }}
                            </h3>
                            <p class="text-muted small mb-3">
                                {{ 'This information will appear on your invoices and quotes.'|trans }}
                            </p>
                            <div class="row g-3">
                                {% if form.company.contact_details.email is defined %}
                                    <div class="col-md-6">
                                        {{ form_row(form.company.contact_details.email, {
                                            label: 'Contact Email'|trans,
                                            attr: {placeholder: 'contact@yourcompany.com'|trans}
                                        }) }}
                                    </div>
                                {% endif %}
                                {% if form.company.contact_details.phone_number is defined %}
                                    <div class="col-md-6">
                                        {{ form_row(form.company.contact_details.phone_number, {
                                            label: 'Phone Number'|trans,
                                            attr: {placeholder: '+1 (555) 123-4567'|trans}
                                        }) }}
                                    </div>
                                {% endif %}
                            </div>
                            {% if form.company.contact_details.address is defined %}
                                <div class="mt-3">
                                    <label class="form-label fw-medium mb-2">{{ 'Business Address'|trans }}</label>
                                    {{ form_widget(form.company.contact_details.address) }}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    {# Custom Domain Section #}
                    {% if form.company.custom_domain is defined %}
                        <div class="mb-4 pb-4 border-bottom">
                            <h3 class="d-flex align-items-center gap-2 mb-3">
                                {{ ux_icon('tabler:world', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                                {{ 'Custom Domain'|trans }}
                            </h3>
                            <p class="text-muted small mb-3">
                                {{ 'Serve SolidInvoice from your own domain (e.g. invoices.yourcompany.com) instead of the default URL.'|trans }}
                            </p>
                            {{ form_row(form.company.custom_domain, {
                                label: 'Custom Domain'|trans,
                                attr: {placeholder: 'invoices.yourcompany.com'}
                            }) }}

                            {% if custom_domain_dns_record is not empty %}
                                <div class="alert alert-info mt-3" role="alert">
                                    <div class="d-flex">
                                        <div class="me-3">
                                            {{ ux_icon('tabler:info-circle', {width: 24, height: 24, 'aria-hidden': 'true'}) }}
                                        </div>
                                        <div class="flex-grow-1">
                                            <h4 class="alert-title mb-1">{{ 'DNS setup required'|trans }}</h4>
                                            <p class="mb-2">
                                                {{ 'After saving, add a CNAME record at your DNS provider so your domain points to SolidInvoice. DNS changes can take up to 24 hours to propagate.'|trans }}
                                            </p>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-bordered mb-2 align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col">{{ 'Type'|trans }}</th>
                                                            <th scope="col">{{ 'Name / Host'|trans }}</th>
                                                            <th scope="col">{{ 'Value / Target'|trans }}</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td><code>CNAME</code></td>
                                                            <td><code>{{ form.company.custom_domain.vars.value|default('invoices.yourcompany.com') }}</code></td>
                                                            <td><code>{{ custom_domain_dns_record }}</code></td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <p class="text-muted small mb-0">
                                                {{ 'Once the CNAME is in place, your custom domain will resolve to SolidInvoice automatically — no further action required.'|trans }}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endif %}

                {# General Settings Section #}
                {% if form.general is defined %}
                    <div>
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:settings', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'General Settings'|trans }}
                        </h3>
                        {{ form_widget(form.general) }}
                    </div>
                {% endif %}

            {% elseif section == 'invoice' or section == 'quote' %}
                {# Invoice/Quote Settings - Custom Layout #}

                {# Display Settings #}
                <div class="mb-4 pb-4 border-bottom">
                    <h3 class="d-flex align-items-center gap-2 mb-3">
                        {{ ux_icon('tabler:eye', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                        {{ 'Display Settings'|trans }}
                    </h3>
                    {% if form.watermark is defined %}
                        {{ form_row(form.watermark, {
                            label: 'Show Status Watermark'|trans,
                            help: 'settings.watermark.help'|trans({'%type%': section|trans})
                        }) }}
                    {% endif %}
                </div>

                {# Email Settings #}
                <div class="mb-4 pb-4 border-bottom">
                    <h3 class="d-flex align-items-center gap-2 mb-3">
                        {{ ux_icon('tabler:mail', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                        {{ 'Email Notifications'|trans }}
                    </h3>
                    <div class="row g-3">
                        {% if form.email_subject is defined %}
                            <div class="col-12">
                                {{ form_row(form.email_subject, {
                                    label: 'Email Subject Line'|trans,
                                    help: 'settings.email_subject.help'|trans({'%type%': section|trans}),
                                    attr: {placeholder: 'settings.email_subject.placeholder'|trans({'%type%': section|trans|title})}
                                }) }}
                            </div>
                        {% endif %}
                        {% if form.bcc_address is defined %}
                            <div class="col-12">
                                {{ form_row(form.bcc_address, {
                                    label: 'BCC Email Address'|trans,
                                    help: 'settings.bcc_address.help'|trans({'%type%': section|trans}),
                                    attr: {placeholder: 'bcc@yourcompany.com'}
                                }) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# ID Generation Settings #}
                {% if form.id_generation is defined %}
                    <div>
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:hash', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'Numbering Scheme'|trans }}
                        </h3>
                        <p class="text-muted small mb-3">
                            {{ 'settings.numbering.description'|trans({'%type%': section|trans}) }}
                        </p>
                        <div class="row g-3">
                            {% if form.id_generation.strategy is defined %}
                                <div class="col-12">
                                    {{ form_row(form.id_generation.strategy, {
                                        label: 'Numbering Strategy'|trans,
                                        help: 'settings.numbering_strategy.help'|trans({'%type%': section|trans})
                                    }) }}
                                </div>
                            {% endif %}
                            {% if form.id_generation.id_prefix is defined %}
                                <div class="col-md-6">
                                    {{ form_row(form.id_generation.id_prefix, {
                                        label: 'ID Prefix'|trans,
                                        help: 'Added before the number. E.g., "INV-" results in INV-001'|trans,
                                        attr: {placeholder: section == 'invoice' ? 'INV-' : 'QUO-'}
                                    }) }}
                                </div>
                            {% endif %}
                            {% if form.id_generation.id_suffix is defined %}
                                <div class="col-md-6">
                                    {{ form_row(form.id_generation.id_suffix, {
                                        label: 'ID Suffix'|trans,
                                        help: 'Added after the number. E.g., "-2024" results in 001-2024'|trans,
                                        attr: {placeholder: '-2024'}
                                    }) }}
                                </div>
                            {% endif %}
                        </div>

                        {# Preview of numbering #}
                        <div class="mt-3 p-3 bg-light rounded-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted small">{{ 'Example:'|trans }}</span>
                                <code class="fs-6">
                                    {% set prefix = form.id_generation.id_prefix.vars.value|default('') %}
                                    {% set suffix = form.id_generation.id_suffix.vars.value|default('') %}
                                    {{ prefix }}001{{ suffix }}
                                </code>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Payment Reminders Section #}
                {% if section == 'invoice' and form.reminder is defined %}
                    <div class="mt-4">
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:bell', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'Payment Reminders'|trans }}
                        </h3>
                        <p class="text-muted small mb-3">
                            {{ 'Automatically send payment reminders to clients for pending invoices. Reminders are sent before the due date and at intervals after the invoice becomes overdue.'|trans }}
                        </p>

                        {# Enable Reminders Toggle #}
                        {% if form.reminder.enabled is defined %}
                            <div class="mb-4">
                                {{ form_row(form.reminder.enabled, {
                                    label: 'Enable Automatic Reminders'|trans,
                                    help: 'When enabled, payment reminders will be sent automatically based on the schedule below.'|trans
                                }) }}
                            </div>
                        {% endif %}

                        {# Reminder Configuration Card #}
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <div class="row g-4">
                                    {# Pre-Due Reminder Settings #}
                                    <div class="col-12">
                                        <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom">
                                            <div class="text-primary mt-1">
                                                {{ ux_icon('tabler:calendar-event', {width: 20, height: 20, 'aria-hidden': 'true'}) }}
                                            </div>
                                            <div class="flex-grow-1">
                                                <h5 class="mb-2">{{ 'Pre-Due Reminder'|trans }}</h5>
                                                <p class="text-muted small mb-3">
                                                    {{ 'Send a friendly reminder before the invoice due date to help clients pay on time.'|trans }}
                                                </p>

                                                {% if form.reminder.pre_due_enabled is defined %}
                                                    {{ form_row(form.reminder.pre_due_enabled, {
                                                        label: 'Enable Pre-Due Reminders'|trans
                                                    }) }}
                                                {% endif %}

                                                {% if form.reminder.pre_due_days is defined %}
                                                    <div class="mt-3">
                                                        {{ form_row(form.reminder.pre_due_days, {
                                                            label: 'Days Before Due Date'|trans,
                                                            help: 'Send the reminder this many days before the invoice is due (0 to send on due date).'|trans,
                                                            attr: {min: 0, max: 30, placeholder: '3'}
                                                        }) }}
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>

                                    {# Overdue Reminder Schedule #}
                                    <div class="col-12">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="text-warning mt-1">
                                                {{ ux_icon('tabler:clock-exclamation', {width: 20, height: 20, 'aria-hidden': 'true'}) }}
                                            </div>
                                            <div class="flex-grow-1">
                                                <h5 class="mb-2">{{ 'Overdue Reminder Schedule'|trans }}</h5>
                                                <p class="text-muted small mb-3">
                                                    {{ 'Automatic reminders are sent at 1, 7, and 14 days after the invoice becomes overdue. After the final (14-day) reminder, an escalation notification is sent to internal users for manual follow-up.'|trans }}
                                                </p>

                                                <div class="alert alert-info d-flex align-items-start gap-2 mb-0" role="status">
                                                    {{ ux_icon('tabler:info-circle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1', 'aria-hidden': 'true'}) }}
                                                    <div class="small">
                                                        <strong>{{ 'Escalating Tone:'|trans }}</strong>
                                                        {{ 'Reminder messages become progressively more urgent: polite at 1 day, firm at 7 days, and urgent at 14 days overdue.'|trans }}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Information Alert #}
                        <div class="alert alert-primary d-flex align-items-start gap-2 mt-3" role="status">
                            {{ ux_icon('tabler:info-circle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1', 'aria-hidden': 'true'}) }}
                            <div class="small">
                                <strong>{{ 'How It Works:'|trans }}</strong>
                                {{ 'Reminders are sent daily at 9:00 AM. Each invoice receives a maximum of 4 automated reminders (1 pre-due + 3 overdue). After the final reminder, you\'ll receive an escalation notification to handle the invoice manually. Paid invoices will not receive reminders.'|trans }}
                            </div>
                        </div>
                    </div>
                {% endif %}

            {% elseif section == 'email' %}
                {# Email Settings - Custom Layout #}

                {# Sender Information #}
                <div class="mb-4 pb-4 border-bottom">
                    <h3 class="d-flex align-items-center gap-2 mb-3">
                        {{ ux_icon('tabler:user', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                        {{ 'Sender Information'|trans }}
                    </h3>
                    <p class="text-muted small mb-3">
                        {{ 'Configure how your emails appear to recipients.'|trans }}
                    </p>
                    <div class="row g-3">
                        {% if form.from_name is defined %}
                            <div class="col-md-6">
                                {{ form_row(form.from_name, {
                                    label: 'From Name'|trans,
                                    help: 'The name that appears in the "From" field.'|trans,
                                    attr: {placeholder: 'Your Company Name'|trans}
                                }) }}
                            </div>
                        {% endif %}
                        {% if form.from_address is defined %}
                            <div class="col-md-6">
                                {{ form_row(form.from_address, {
                                    label: 'From Email Address'|trans,
                                    help: 'Replies will be sent to this address.'|trans,
                                    attr: {placeholder: 'no-reply@yourcompany.com'|trans}
                                }) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Mail Provider Settings #}
                {% if form.sending_options is defined %}
                    <div>
                        <h3 class="d-flex align-items-center gap-2 mb-3">
                            {{ ux_icon('tabler:server', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
                            {{ 'Email Delivery'|trans }}
                        </h3>
                        <p class="text-muted small mb-3">
                            {{ 'Choose and configure your email delivery service.'|trans }}
                        </p>
                        {{ form_widget(form.sending_options) }}
                    </div>
                {% endif %}

            {% else %}
                {# Default Rendering for Other Sections #}
                {{ form_widget(form) }}
            {% endif %}
        </div>

        {# Save Button Footer #}
        <div class="card-footer bg-transparent border-top">
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-save" aria-label="{{ 'Save Settings'|trans }}">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18, 'aria-hidden': 'true'}) }}
                    {{ 'Save Settings'|trans }}
                </button>
            </div>
        </div>
    </div>

    {{ form_end(form) }}

    {# Danger Zone - Only for System Section #}
    {% if section is same as('system') %}
        <div class="settings-danger-zone mt-4" role="region" aria-labelledby="danger-zone-heading"
             {{ stimulus_controller('delete-company', {'company-name': company_name()}) }}>
            <div class="card border-danger">
                <div class="card-header bg-danger bg-opacity-10 border-danger">
                    <h5 class="card-title text-danger mb-0 d-flex align-items-center gap-2" id="danger-zone-heading">
                        {{ ux_icon('tabler:alert-triangle', {width: 20, height: 20, 'aria-hidden': 'true'}) }}
                        {{ 'Danger Zone'|trans }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-3">
                        <div>
                            <h3 class="mb-1">{{ 'Delete Company'|trans }}</h3>
                            <p class="text-muted mb-0">
                                {{ 'Permanently delete your company and all associated data. This action cannot be undone.'|trans }}
                            </p>
                        </div>
                        <button type="button"
                                class="btn btn-outline-danger flex-shrink-0 gap-2"
                                aria-label="{{ 'Delete Company'|trans }}"
                                {{ stimulus_action('delete-company', 'showModal', 'click') }}>
                            {{ ux_icon('tabler:trash', {width: 16, height: 16, 'aria-hidden': 'true'}) }}
                            {{ 'Delete Company'|trans }}
                        </button>
                    </div>
                </div>
            </div>

            {# Delete Company Modal #}
            <div class="modal fade"
                 id="deleteCompanyModal"
                 tabindex="-1"
                 aria-labelledby="deleteCompanyModalLabel"
                 aria-hidden="true"
                 {{ stimulus_target('delete-company', 'modal') }}>
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title text-danger d-flex align-items-center gap-2" id="deleteCompanyModalLabel">
                                {{ ux_icon('tabler:alert-triangle', {width: 20, height: 20, 'aria-hidden': 'true'}) }}
                                {{ 'Confirm Company Deletion'|trans }}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                        </div>
                        <div class="modal-body">
                            <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                                {{ ux_icon('tabler:alert-circle', {width: 20, height: 20, class: 'flex-shrink-0 mt-1', 'aria-hidden': 'true'}) }}
                                <div>
                                    <strong>{{ 'Warning!'|trans }}</strong>
                                    {{ 'This action will permanently delete your company and all associated data including invoices, quotes, clients, and payments. This cannot be undone.'|trans }}
                                </div>
                            </div>
                            <p class="mb-2">
                                {{ 'To confirm deletion, please type the company name exactly as shown below:'|trans }}
                            </p>
                            <p class="fw-bold text-danger fs-5 mb-3 font-monospace" aria-label="{{ 'Company name to type'|trans }}">{{ company_name() }}</p>
                            <div class="mb-3">
                                <label for="companyNameConfirmation" class="form-label">
                                    {{ 'Company Name'|trans }}
                                </label>
                                <input type="text"
                                       class="form-control"
                                       id="companyNameConfirmation"
                                       name="company_name"
                                       form="deleteCompanyForm"
                                       autocomplete="off"
                                       aria-required="true"
                                       {{ stimulus_target('delete-company', 'companyNameInput') }}
                                       {{ stimulus_action('delete-company', 'validateInput', 'input') }}
                                       placeholder="{{ 'Enter company name to confirm'|trans }}">
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">
                                {{ 'Cancel'|trans }}
                            </button>
                            <form id="deleteCompanyForm" action="{{ path('_delete_company') }}" method="post" class="d-inline">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_company') }}">
                                <button type="submit"
                                        class="btn btn-danger gap-2"
                                        aria-label="{{ 'Delete Company'|trans }}"
                                        {{ stimulus_target('delete-company', 'confirmButton') }}
                                        disabled>
                                    {{ ux_icon('tabler:trash', {width: 16, height: 16, 'aria-hidden': 'true'}) }}
                                    {{ 'Delete Company'|trans }}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
