{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block content %}
<div class="form-page">
    {{ form_start(form) }}

    {{ form_errors(form) }}

    <div class="form-page-container form-page-container--narrow">
        {# Page Header #}
        <div class="form-page-header">
            <div class="form-page-header-content">
                <div class="form-page-icon">
                    {{ ux_icon('tabler:receipt-tax', {width: 28, height: 28}) }}
                </div>
                <div>
                    {% if form.vars.data.name is not empty %}
                        <h1 class="form-page-title">{{ 'tax.rates.edit'|trans }}</h1>
                    {% else %}
                        <h1 class="form-page-title">{{ 'tax.rates.add'|trans }}</h1>
                        <p class="form-page-subtitle">{{ 'tax.rates.form.subtitle'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Main Form Content #}
        <div class="form-page-sections">
            <section class="form-page-section" id="tax-details">
                <div class="section-header">
                    <div class="section-icon">
                        {{ ux_icon('tabler:settings', {width: 20, height: 20}) }}
                    </div>
                    <div class="section-header-text">
                        <h2 class="section-title">{{ 'tax.rates.details'|trans }}</h2>
                        <p class="section-description">{{ 'tax.rates.form.description'|trans }}</p>
                    </div>
                </div>

                <div class="section-content">
                    <div class="form-grid">
                        <div class="form-field form-field-wide">
                            {{ form_row(form.name) }}
                        </div>

                        <div class="form-field">
                            {{ form_row(form.rate) }}
                        </div>

                        <div class="form-field">
                            {{ form_row(form.type) }}
                        </div>
                    </div>
                </div>
            </section>
        </div>

        {{ form_rest(form) }}

        {# Sticky Footer with Actions #}
        <div class="form-page-actions">
            <div class="form-page-actions-inner">
                <a href="{{ path('_tax_rates') }}" class="btn btn-ghost">
                    {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                    {{ 'tax.rates.cancel'|trans }}
                </a>
                <button type="submit" class="btn btn-primary btn-save">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'tax.rates.save'|trans }}
                </button>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
