{% set menuItem = 'change-password' %}

{% extends "@SolidInvoiceUser/Layout/profile.html.twig" %}

{% block title %}{{ ux_icon('tabler:lock', {width: 24, height: 24, class: 'me-2'}) }}{{ "Change Password"|trans }}{% endblock title %}

{% block profile_content %}
    <div class="form-page">
        {{ form_start(form) }}

        {{ form_errors(form) }}

        <div class="form-page-container form-page-container--narrow">
            {# Page Header #}
            <div class="form-page-header">
                <div class="form-page-header-content">
                    <div class="form-page-icon form-page-icon--security">
                        {{ ux_icon('tabler:lock', {width: 28, height: 28}) }}
                    </div>
                    <div>
                        <h1 class="form-page-title">{{ 'Change Password'|trans }}</h1>
                        <p class="form-page-subtitle">{{ 'Update your password to keep your account secure'|trans }}</p>
                    </div>
                </div>
            </div>

            {# Password Requirements #}
            <div class="password-requirements">
                <div class="password-requirements-header">
                    <div class="section-icon">
                        {{ ux_icon('tabler:info-circle', {width: 16, height: 16}) }}
                    </div>
                    <h3>{{ 'Password Requirements'|trans }}</h3>
                </div>
                <ul class="password-requirements-list">
                    <li>{{ 'At least 8 characters long'|trans }}</li>
                    <li>{{ 'Use a mix of letters, numbers, and symbols for better security'|trans }}</li>
                    <li>{{ 'Avoid passwords that have been compromised in data breaches'|trans }}</li>
                </ul>
            </div>

            {# Main Form Content #}
            <div class="form-page-sections">
                <section class="form-page-section" id="password-details">
                    <div class="section-header">
                        <div class="section-icon section-icon--security">
                            {{ ux_icon('tabler:shield-lock', {width: 20, height: 20}) }}
                        </div>
                        <div class="section-header-text">
                            <h2 class="section-title">{{ 'Update Your Password'|trans }}</h2>
                            <p class="section-description">{{ 'Enter your current password and choose a new one'|trans }}</p>
                        </div>
                    </div>

                    <div class="section-content">
                        <div class="form-grid">
                            {% if form.currentPassword is defined %}
                                <div class="form-field form-field-wide">
                                    {{ form_row(form.currentPassword) }}
                                </div>
                            {% endif %}

                            {% if form.plainPassword is defined %}
                                <div class="form-field form-field-wide">
                                    {{ form_row(form.plainPassword.first) }}
                                </div>

                                <div class="form-field form-field-wide">
                                    {{ form_row(form.plainPassword.second) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </section>
            </div>

            {{ form_rest(form) }}

            {# Sticky Footer with Actions #}
            <div class="form-page-actions">
                <div class="form-page-actions-inner">
                    <a href="{{ path('_profile') }}" class="btn btn-ghost">
                        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                        {{ 'profile.edit.cancel'|trans }}
                    </a>
                    <button type="submit" class="btn btn-primary btn-save">
                        {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                        {{ 'change_password.submit'|trans }}
                    </button>
                </div>
            </div>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock profile_content %}
