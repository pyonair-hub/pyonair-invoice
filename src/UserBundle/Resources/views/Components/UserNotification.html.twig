<div {{ attributes }} class="form-page">
    <div class="form-page-container form-page-container--medium">
        {{ form_start(form, {
            attr: {
                'data-action': 'live#action:prevent',
                'data-live-action-param': 'save'
            }
        }) }}

        {# Page Header #}
        <div class="form-page-header">
            <div class="form-page-header-content">
                <div class="form-page-icon">
                    {{ ux_icon('tabler:bell-ringing', {width: 28, height: 28}) }}
                </div>
                <div>
                    <h1 class="form-page-title">{{ 'Notification Preferences'|trans }}</h1>
                    <p class="form-page-subtitle">
                        {{ 'Choose which events trigger notifications and where you receive them'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# Integration Management Section #}
        {% set availableTransports = this.allTransports %}
        <div class="integration-management-card">
            <div class="integration-management-header">
                <div class="integration-management-icon">
                    {{ ux_icon('tabler:plug-connected', {width: 20, height: 20}) }}
                </div>
                <div class="integration-management-info">
                    <h2 class="integration-management-title">{{ 'Notification Channels'|trans }}</h2>
                    <p class="integration-management-description">
                        {% if availableTransports|length > 0 %}
                            {{ 'You have %count% integration(s) configured'|trans({'%count%': availableTransports|length + 1}) }}
                        {% else %}
                            {{ 'Email notifications are always available. Add integrations to receive notifications via other channels.'|trans }}
                        {% endif %}
                    </p>
                </div>
                <a href="{{ path('_notification_integration') }}" class="btn btn-primary">
                    {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
                    {{ 'Manage Integrations'|trans }}
                </a>
            </div>

            {% if availableTransports|length > 0 %}
                <div class="integration-management-list">
                    <div class="integration-badge">
                        {{ ux_icon('tabler:mail', {width: 16, height: 16}) }}
                        <span>{{ 'Email'|trans }}</span>
                    </div>
                    {% for transport in availableTransports %}
                        <div class="integration-badge">
                            {{ ux_icon(this.getTransportIcon(transport.transport), {width: 16, height: 16}) }}
                            <span>{{ transport.name }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Notification Groups #}
        {% set groupedNotifications = this.groupNotificationsByCategory() %}

        {% if groupedNotifications|length > 0 %}
            <div class="notification-groups">
                {% for category, events in groupedNotifications %}
                    <div class="notification-group">
                        <h2 class="group-title">
                            {{ ux_icon(this.getCategoryIcon(category), {width: 20, height: 20}) }}
                            {{ category|trans }}
                        </h2>

                        <div class="notification-cards">
                            {% for event in events %}
                                <div class="notification-card">
                                    <div class="notification-card-content">
                                        <div class="notification-card-icon">
                                            {{ ux_icon(this.getEventIcon(event), {width: 20, height: 20}) }}
                                        </div>
                                        <div class="notification-card-info">
                                            <h3 class="notification-title">{{ this.getEventTitle(event)|trans }}</h3>
                                            <p class="notification-description">{{ this.getEventDescription(event)|trans }}</p>
                                        </div>
                                    </div>
                                    <div class="notification-card-channels">
                                        {{ form_widget(attribute(form, event).transports) }}
                                        {{ form_widget(attribute(form, event).event) }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {# Empty State - No Notifications or Integrations #}
        {% if groupedNotifications|length == 0 %}
            <div class="empty">
                <div class="empty-icon">
                    {{ ux_icon('tabler:bell-off', {width: 48, height: 48}) }}
                </div>
                <p class="empty-title">{{ 'No Notifications Available'|trans }}</p>
                <p class="empty-subtitle text-secondary">{{ 'Notification events will appear here when they are available in the system'|trans }}</p>
            </div>
        {% endif %}

        {# Sticky Footer Actions #}
        <div class="form-page-actions">
            <div class="form-page-actions-inner form-page-actions-inner--medium">
                <a href="{{ path('_profile') }}" class="btn btn-ghost">
                    {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                    {{ 'Cancel'|trans }}
                </a>
                <button type="submit" class="btn btn-primary btn-save">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'Save Preferences'|trans }}
                </button>
            </div>
        </div>

        {{ form_end(form) }}
    </div>
</div>
