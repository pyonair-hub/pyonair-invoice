{% extends '@SolidInvoiceCore/Layout/Email/base.html.twig' %}
{% import "@SolidInvoiceCore/Layout/Email/components.html.twig" as email %}

{%- block title -%}
    {{ 'email.confirmation.title'|trans({}, 'email') }}
{%- endblock -%}

{%- block content -%}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #1e293b; font-size: 16px; line-height: 1.5; margin: 0 0 16px 0; Margin: 0 0 16px 0;">
                    {{ 'email.confirmation.message'|trans({}, 'email') }}
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('md') }}

    {# Confirm button #}
    {{ email.button('email.confirmation.button'|trans({}, 'email'), signedUrl, 'primary', 'large') }}

    {{ email.spacer('md') }}

    {# Alternative link #}
    {% apply inky_to_html %}
        <row>
            <columns>
                <p style="color: #626976; font-size: 14px; line-height: 1.5; margin: 0; Margin: 0; text-align: center;">
                    {{ 'email.confirmation.alternative'|trans({}, 'email') }}
                </p>
                <p style="color: #206bc4; font-size: 14px; margin: 8px 0 0 0; Margin: 8px 0 0 0; text-align: center; word-break: break-all;">
                    <a href="{{ signedUrl }}" rel="external" target="_blank" style="color: #206bc4; text-decoration: none;">{{ signedUrl }}</a>
                </p>
            </columns>
        </row>
    {% endapply %}

    {{ email.spacer('md') }}

    {# Security notice #}
    {{ email.alert_box('email.confirmation.security'|trans({}, 'email'), 'info') }}

    {{ email.spacer('sm') }}
{%- endblock -%}
