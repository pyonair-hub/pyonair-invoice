{% extends "@SolidInvoiceCore/Layout/default_no_nav.html.twig" %}

{% block title %}{{ "forgot_password.request.title"|trans }}{% endblock title %}

{% block content %}
    <div class="container-tight py-4">
        <div class="text-center mb-4">
            <span class="navbar-brand navbar-brand-autodark h1">
                {{ app_logo(showDefault: true, showOnlyAppIcon: true) }} {{ app_name }}
            </span>
        </div>

        {% include "@SolidInvoiceCore/flash.html.twig" %}

        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">{{ 'forgot_password.request.heading'|trans }}</h2>
                <p class="text-muted text-center mb-4">
                    {{ 'forgot_password.request.description'|trans }}
                </p>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_row(form.email) }}
                    </div>
                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100">
                            {{ ux_icon('tabler:lock', {width: 20, height: 20}) }}
                            {{ 'forgot_password.request.submit'|trans }}
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="text-center text-secondary mt-3">
            <a href="{{ path('_login_main') }}" class="d-flex align-items-center justify-content-center gap-1">
                {{ ux_icon('tabler:arrow-left', {width: 16, height: 16}) }}
                {{ 'forgot_password.request.back_to_login'|trans }}
            </a>
        </div>
    </div>
{% endblock %}
