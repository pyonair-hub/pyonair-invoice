<div class="onboarding-step-card">
    <div class="step-icon">
        {{ ux_icon('tabler:users', {width: 32, height: 32, class: 'text-white'}) }}
    </div>

    <h2 class="h2 text-center mb-2">{{ 'onboarding.client.title'|trans({}, 'onboarding') }}</h2>
    <p class="text-muted text-center lead mb-4">
        {{ 'onboarding.client.description'|trans({}, 'onboarding') }}
    </p>

    {# Benefits Box #}
    <div class="step-benefits">
        <div class="d-flex align-items-start gap-2">
            {{ ux_icon('tabler:bulb', {width: 20, height: 20, class: 'text-warning mt-1'}) }}
            <div>
                <strong class="d-block mb-1">{{ 'onboarding.client.why_title'|trans({}, 'onboarding') }}</strong>
                <ul class="mb-0">
                    {% for benefit in 'onboarding.client.benefits'|trans({}, 'onboarding')|trim|split("\n") %}
                        <li>{{ benefit }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    {{ form_start(form) }}
        <div class="mb-3">
            {{ form_row(form.client.clientName, {
                'attr': {
                    'class': 'form-control form-control-lg'
                }
            }) }}
        </div>

        <div class="mb-4">
            {{ form_row(form.client.clientEmail, {
                'attr': {
                    'class': 'form-control form-control-lg'
                }
            }) }}
        </div>

        <div class="d-grid gap-2">
            {{ form_widget(form.navigator.next, {
                'attr': {'class': 'btn btn-primary btn-lg w-100'}
            }) }}

            {{ form_widget(form.navigator.skip, {
                'label': 'onboarding.navigation.skip_client'|trans({}, 'onboarding'),
                'attr': {'class': 'btn btn-link w-100 mt-2 text-muted small'}
            }) }}

            {{ form_widget(form.navigator.back, {
                'attr': {'class': 'btn btn-link w-100 mt-2 text-muted'}
            }) }}
        </div>
    {{ form_end(form) }}
</div>
