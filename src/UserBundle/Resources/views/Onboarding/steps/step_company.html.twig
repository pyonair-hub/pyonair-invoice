<div class="onboarding-step-card">
    {# Welcome Badge #}
    <div class="welcome-section">
        <div class="welcome-badge">
            {{ ux_icon('tabler:sparkles', {width: 16, height: 16}) }}
            {{ 'Welcome to %app_name%!'|trans({'%app_name%': app_name}) }}
        </div>
        <div class="step-icon">
            {{ ux_icon('tabler:building', {width: 32, height: 32, class: 'text-white'}) }}
        </div>
        <h2 class="h2 mb-2">{{ 'onboarding.company.title'|trans({}, 'onboarding') }}</h2>
        <p class="text-muted lead mb-0">
            {{ 'onboarding.company.description'|trans({}, 'onboarding') }}
        </p>
    </div>

    {# Benefits Box #}
    <div class="step-benefits">
        <div class="d-flex align-items-start gap-2 mb-2">
            {{ ux_icon('tabler:info-circle', {width: 20, height: 20, class: 'text-primary mt-1'}) }}
            <div>
                <strong class="d-block mb-1">{{ 'onboarding.company.setup_title'|trans({}, 'onboarding') }}</strong>
                <ul class="mb-0">
                    {% for benefit in 'onboarding.company.benefits'|trans({}, 'onboarding')|trim|split("\n") %}
                        <li>{{ benefit }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    <h3 class="h4 mb-3">{{ 'onboarding.company.subtitle'|trans({}, 'onboarding') }}</h3>

    {{ form_start(form) }}
        <div class="mb-4">
            {{ form_row(form.company.companyName, {
                'attr': {
                    'class': 'form-control form-control-lg',
                }
            }) }}
        </div>

        <div class="mb-4">
            {{ form_row(form.company.companyCurrency, {
                'attr': {'class': 'form-control'}
            }) }}
        </div>

        <div class="d-grid gap-2">
            {{ form_widget(form.navigator.next, {
                'attr': {'class': 'btn btn-primary btn-lg w-100'}
            }) }}
        </div>
    {{ form_end(form) }}
</div>
