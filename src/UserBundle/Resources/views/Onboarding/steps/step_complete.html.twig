<div class="onboarding-step-card text-center">
    {# Success Animation #}
    <div class="celebration-icon mb-4">
        <div class="success-checkmark">
            {{ ux_icon('tabler:circle-check', {width: 96, height: 96, class: 'text-success'}) }}
        </div>
    </div>

    <h1 class="h1 mb-3">{{ 'onboarding.complete.title'|trans({}, 'onboarding') }}</h1>
    <p class="lead text-muted mb-4">
        {{ 'onboarding.complete.description'|trans({}, 'onboarding') }}
    </p>

    {# Next Steps #}
    <div class="step-benefits text-start mb-4">
        <div class="d-flex align-items-start gap-2">
            {{ ux_icon('tabler:checklist', {width: 20, height: 20, class: 'text-primary mt-1'}) }}
            <div>
                <strong class="d-block mb-2">{{ 'onboarding.complete.next_title'|trans({}, 'onboarding') }}</strong>
                <ul class="mb-0">
                    {% for step in 'onboarding.complete.next_steps'|trans({}, 'onboarding')|trim|split("\n") %}
                        <li>{{ step }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    {# Quick Tips #}
    <div class="alert alert-info d-flex align-items-start gap-3 mb-4" role="alert">
        {{ ux_icon('tabler:bulb', {width: 20, height: 20, class: 'flex-shrink-0 mt-1'}) }}
        <div class="text-start">
            <strong>{{ 'onboarding.complete.pro_tip_title'|trans({}, 'onboarding') }}</strong> {{ 'onboarding.complete.pro_tip_text'|trans({}, 'onboarding') }}
        </div>
    </div>

    {% if hasClient %}
        {# Client exists but no invoice yet — direct them to create one #}
        <div class="d-grid gap-3 mb-3">
            <a href="{{ path('_invoices_create') }}" class="btn btn-primary btn-lg">
                {{ 'onboarding.complete.cta_create_invoice'|trans({}, 'onboarding') }}
            </a>
        </div>
        {{ form_start(form) }}
            {{ form_widget(form.navigator.finish, {
                'attr': {'class': 'btn btn-link text-muted w-100'}
            }) }}
        {{ form_end(form) }}
    {% else %}
        {# No client or invoice — show next-step mini checklist #}
        <div class="mb-4">
            <p class="fw-semibold mb-2">{{ 'onboarding.complete.next_steps_title'|trans({}, 'onboarding') }}</p>
            <div class="list-group text-start">
                <a href="{{ path('_clients_add') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    {{ ux_icon('tabler:users', {width: 18, height: 18, class: 'text-primary flex-shrink-0'}) }}
                    {{ 'onboarding.complete.next_add_client'|trans({}, 'onboarding') }}
                </a>
                <a href="{{ path('_invoices_create') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    {{ ux_icon('tabler:file-invoice', {width: 18, height: 18, class: 'text-primary flex-shrink-0'}) }}
                    {{ 'onboarding.complete.next_send_invoice'|trans({}, 'onboarding') }}
                </a>
                <a href="{{ path('_payment_settings_index') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    {{ ux_icon('tabler:credit-card', {width: 18, height: 18, class: 'text-primary flex-shrink-0'}) }}
                    {{ 'onboarding.complete.next_connect_payment'|trans({}, 'onboarding') }}
                </a>
            </div>
        </div>
        {{ form_start(form) }}
            {{ form_widget(form.navigator.finish, {
                'attr': {'class': 'btn btn-outline-secondary w-100'}
            }) }}
        {{ form_end(form) }}
    {% endif %}

    <div class="mt-4 pt-3 border-top">
        <p class="text-muted small mb-2">
            {{ ux_icon('tabler:heart', {width: 16, height: 16, class: 'text-danger'}) }}
            {{ 'Thanks for choosing %app_name%'|trans({'%app_name%': app_name}) }}
        </p>
        <p class="text-muted small mb-0">
            {{ 'Need help? Check out our'|trans }}
            <a href="https://solidinvoice.co/docs" target="_blank" rel="noopener" class="text-primary">{{ 'onboarding.complete.docs_link'|trans({}, 'onboarding') }}</a>
        </p>
    </div>
</div>

<style>
    .celebration-icon {
        animation: celebrate 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    @keyframes celebrate {
        0% {
            transform: scale(0) rotate(-180deg);
            opacity: 0;
        }
        50% {
            transform: scale(1.1) rotate(10deg);
        }
        100% {
            transform: scale(1) rotate(0deg);
            opacity: 1;
        }
    }

    .success-checkmark {
        position: relative;
    }

    .success-checkmark::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(40, 167, 69, 0.1);
        animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.5;
        }
        50% {
            transform: translate(-50%, -50%) scale(1.1);
            opacity: 0.3;
        }
    }
</style>
