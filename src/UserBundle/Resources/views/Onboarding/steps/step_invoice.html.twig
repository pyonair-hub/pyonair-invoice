<div class="onboarding-step-card">
    <div class="step-icon">
        {{ ux_icon('tabler:file-invoice', {width: 32, height: 32, class: 'text-white'}) }}
    </div>

    <h2 class="h2 text-center mb-2">{{ 'onboarding.invoice.title'|trans({}, 'onboarding') }}</h2>
    <p class="text-muted text-center lead mb-4">
        {{ 'onboarding.invoice.description'|trans({}, 'onboarding') }}
    </p>

    {# Benefits Box #}
    <div class="step-benefits">
        <div class="d-flex align-items-start gap-2">
            {{ ux_icon('tabler:rocket', {width: 20, height: 20, class: 'text-success mt-1'}) }}
            <div>
                <strong class="d-block mb-1">{{ 'onboarding.invoice.aha_title'|trans({}, 'onboarding') }}</strong>
                <ul class="mb-0">
                    {% for benefit in 'onboarding.invoice.benefits'|trans({}, 'onboarding')|trim|split("\n") %}
                        <li>{{ benefit }}</li>
                    {% endfor %}
                </ul>
                <p class="text-muted small mb-0 mt-2">
                    {{ ux_icon('tabler:clock', {width: 14, height: 14}) }}
                    {{ 'onboarding.invoice.time'|trans({}, 'onboarding') }}
                </p>
            </div>
        </div>
    </div>

    {{ form_start(form) }}
        <div class="mb-3">
            {{ form_row(form.invoice.invoiceDescription, {
                'attr': {
                    'class': 'form-control'
                }
            }) }}
        </div>

        <div class="mb-4">
            {{ form_row(form.invoice.invoiceAmount, {
                'attr': {
                    'class': 'form-control form-control-lg'
                }
            }) }}
        </div>

        <div class="d-grid gap-2">
            {{ form_widget(form.navigator.next, {
                'attr': {'class': 'btn btn-success btn-lg w-100'}
            }) }}

            {{ form_widget(form.navigator.skip, {
                'attr': {'class': 'btn btn-link w-100 mt-2 text-muted'}
            }) }}

            {{ form_widget(form.navigator.back, {
                'attr': {'class': 'btn btn-link w-100 mt-2 text-muted'}
            }) }}
        </div>
    {{ form_end(form) }}

    <div class="text-center mt-3">
        <small class="text-muted">
            {{ ux_icon('tabler:shield-check', {width: 14, height: 14}) }}
            {{ 'onboarding.invoice.security'|trans({}, 'onboarding') }}
        </small>
    </div>
</div>
