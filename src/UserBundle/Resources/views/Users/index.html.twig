{% extends '@SolidInvoiceCore/Layout/default.html.twig' %}

{% block title %}
    {{ ux_icon('tabler:users', {width: 24, height: 24, class: 'me-2'}) }}
    {{ 'users.title'|trans }}
{% endblock title %}

{% block heading %}
    <a class="btn btn-primary" href="{{ path("_user_invite") }}">
        {{ ux_icon('tabler:user-plus', {width: 18, height: 18}) }}
        {{ "users.invite_user"|trans }}
    </a>
{% endblock %}

{% block content %}
    {# KPI Stats Row #}
    <div class="row row-deck row-cards mb-4">
        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-primary text-white avatar">
                                {{ ux_icon('tabler:users', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ totalActiveUsers }}
                            </div>
                            <div class="text-secondary">
                                {{ 'users.stats.active_users'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-warning text-white avatar">
                                {{ ux_icon('tabler:mail-forward', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ totalPendingInvitations }}
                            </div>
                            <div class="text-secondary">
                                {{ 'users.stats.pending_invitations'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-info text-white avatar">
                                {{ ux_icon('tabler:user-check', {width: 24, height: 24}) }}
                            </span>
                        </div>
                        <div class="col">
                            <div class="fw-medium">
                                {{ recentlyJoinedCount }}
                            </div>
                            <div class="text-secondary">
                                {{ 'users.stats.recently_joined'|trans }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Users & Invitations Card with Tabs #}
    <twig:Ui:Card>
        <twig:block name="header">
            <div class="d-flex justify-content-between align-items-center w-100">
                <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link active" id="users-tab-btn" data-bs-toggle="tab" data-bs-target="#users-tab" role="tab" aria-controls="users-tab" aria-selected="true">
                            {{ ux_icon('tabler:users', {width: 16, height: 16}) }}
                            {{ 'users.tabs.active_users'|trans }}
                            <span class="badge bg-primary-lt ms-2">{{ totalActiveUsers }}</span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link" id="invitations-tab-btn" data-bs-toggle="tab" data-bs-target="#invitations-tab" role="tab" aria-controls="invitations-tab" aria-selected="false">
                            {{ ux_icon('tabler:mail', {width: 16, height: 16}) }}
                            {{ 'users.tabs.pending_invitations'|trans }}
                            <span class="badge bg-warning-lt ms-2">{{ totalPendingInvitations }}</span>
                        </button>
                    </li>
                </ul>
            </div>
        </twig:block>

        <div class="tab-content">
            <div class="tab-pane active show" id="users-tab" role="tabpanel" aria-labelledby="users-tab-btn">
                {% if totalActiveUsers == 0 %}
                    <div class="empty">
                        <div class="empty-icon">
                            {{ ux_icon('tabler:users', {width: 48, height: 48, class: 'text-secondary'}) }}
                        </div>
                        <p class="empty-title">{{ 'users.empty.title'|trans }}</p>
                        <p class="empty-subtitle text-secondary">
                            {{ 'users.empty.description'|trans }}
                        </p>
                        <div class="empty-action">
                            <a href="{{ path('_user_invite') }}" class="btn btn-primary">
                                {{ ux_icon('tabler:user-plus', {width: 18, height: 18}) }}
                                {{ 'users.invite_user'|trans }}
                            </a>
                        </div>
                    </div>
                {% else %}
                    <twig:DataGrid name="users_list" />
                {% endif %}
            </div>

            <div class="tab-pane" id="invitations-tab" role="tabpanel" aria-labelledby="invitations-tab-btn">
                {% if totalPendingInvitations == 0 %}
                    <div class="empty">
                        <div class="empty-icon">
                            {{ ux_icon('tabler:mail-opened', {width: 48, height: 48, class: 'text-secondary'}) }}
                        </div>
                        <p class="empty-title">{{ 'users.invitations.empty.title'|trans }}</p>
                        <p class="empty-subtitle text-secondary">
                            {{ 'users.invitations.empty.description'|trans }}
                        </p>
                        <div class="empty-action">
                            <a href="{{ path('_user_invite') }}" class="btn btn-primary">
                                {{ ux_icon('tabler:user-plus', {width: 18, height: 18}) }}
                                {{ 'users.invite_user'|trans }}
                            </a>
                        </div>
                    </div>
                {% else %}
                    <twig:DataGrid name="user_invitations" />
                {% endif %}
            </div>
        </div>
    </twig:Ui:Card>
{% endblock %}
