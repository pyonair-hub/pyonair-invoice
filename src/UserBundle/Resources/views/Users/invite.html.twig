{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block content %}
<div class="form-page">
    {{ form_start(form) }}

    {{ form_errors(form) }}

    <div class="form-page-container form-page-container--narrow">
        {# Page Header #}
        <div class="form-page-header">
            <div class="form-page-header-content">
                <div class="form-page-icon">
                    {{ ux_icon('tabler:user-plus', {width: 28, height: 28}) }}
                </div>
                <div>
                    <h1 class="form-page-title">{{ 'users.invite.title'|trans }}</h1>
                    <p class="form-page-subtitle">{{ 'users.invite.subtitle'|trans }}</p>
                </div>
            </div>
        </div>

        {# Main Form Content #}
        <div class="form-page-sections">
            <section class="form-page-section" id="invitation-details">
                <div class="section-header">
                    <div class="section-icon">
                        {{ ux_icon('tabler:mail', {width: 20, height: 20}) }}
                    </div>
                    <div class="section-header-text">
                        <h2 class="section-title">{{ 'users.invite.details.title'|trans }}</h2>
                        <p class="section-description">{{ 'users.invite.details.description'|trans }}</p>
                    </div>
                </div>

                <div class="section-content">
                    <div class="form-grid">
                        <div class="form-field form-field-wide">
                            {{ form_row(form.email, {
                                label: 'users.invite.email.label'|trans,
                                help: 'users.invite.email.help'|trans,
                                attr: {
                                    placeholder: 'example@company.com',
                                    autocomplete: 'email'
                                }
                            }) }}
                        </div>
                    </div>
                </div>
            </section>

            {# Info Box #}
            <twig:Ui:Alert type="info" icon="tabler:info-circle">
                {{ 'users.invite.info'|trans }}
            </twig:Ui:Alert>
        </div>

        {{ form_rest(form) }}

        {# Sticky Footer with Actions #}
        <div class="form-page-actions">
            <div class="form-page-actions-inner">
                <a href="{{ path('_users_list') }}" class="btn btn-ghost">
                    {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
                    {{ 'profile.edit.cancel'|trans }}
                </a>
                <button type="submit" class="btn btn-primary btn-save">
                    {{ ux_icon('tabler:send', {width: 18, height: 18}) }}
                    {{ 'users.invite.send'|trans }}
                </button>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
